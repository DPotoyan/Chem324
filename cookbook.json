"executable":true,"value":"def plot_orthogonality():\n    '''Defining functions to encampuslate code is a good habit'''\n\n    # Define the range of x values\n    x = np.linspace(0, 2 * np.pi, 1000)\n    \n    # Calculate sin(x) and cos(x)\n    y_sin = np.sin(x)\n    y_cos = np.cos(x)\n    \n    # Plotting sin(x) and cos(x)\n    plt.plot(x, y_sin, label='sin(x)')\n    plt.plot(x, y_cos, label='cos(x)')\n    \n    # Fill the area between two horizontal curves (optional)\n    plt.fill_between(x, y_sin * y_cos, alpha=0.3, color='gray', label='sin(x) * cos(x)')\n    \n    # Labels and title\n    plt.xlabel('x')\n    plt.ylabel('Function Value')\n    plt.title('Orthogonality of sin(x) and cos(x)')\n    plt.legend()\n    plt.grid(True)\n    plt.show()\n\n# Call the function\nplot_orthogonality()","key":"D7dvZx8fOp"},{"type":"outputs","id":"OFJtPyJ_RHOtxnZvnLFVn","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{"image/png":{"width":588,"height":453}},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"1761cc8bf02173d1c41f8c08adab537d","path":"/Chem324/build/1761cc8bf02173d1c41f8c08adab537d.png"}}},"key":"wTwnfBeI7l"}],"key":"kQjst6FEKI"}],"key":"BR9zfQFBuA"}],"key":"KeOWUmPNMY"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Animations with Matplotlib","url":"/demo-animations","group":"Appendix B: Python and Scientific Computing"},"next":{"title":"Classical Mechanics: From Newton to Hamilton","url":"/classical-mechanics","group":"Appendix C: Classical Foundations"}}},"domain":"http://localhost:3000"}