 Print the result\nprint(f\"The numerical integral (dot product) of sin(x) * cos(x) over [0, 2π] is approximately: {dot_product:.4f}\")","key":"nD9G8swGFi"},{"type":"outputs","id":"Pwv_KQ7O8jPmH6zUJcxta","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"The numerical integral (dot product) of sin(x) * cos(x) over [0, 2π] is approximately: -0.0000\n"},"key":"QclS52gqXO"}],"key":"qTbLPo0Wyr"}],"key":"aSaayuXsOD"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Symbolic solution","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"fQilDRxVSh"}],"identifier":"symbolic-solution","label":"Symbolic solution","html_id":"symbolic-solution","implicit":true,"key":"kb3Ak1pkJ1"}],"key":"C6p7FiiEU8"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Define the symbolic variable\nx = sp.symbols('x')\n\n# Define sin(x) and cos(x)\nsin_x = sp.sin(x)\ncos_x = sp.cos(x)\n\n# Calculate the symbolic integral of sin(x) * cos(x) over [0, 2π]\nintegral = sp.integrate(sin_x * cos_x, (x, 0, 2 * sp.pi))\n\n# Print the result\nprint(f\"The symbolic integral of sin(x) * cos(x) over [0, 2π] is: {integral}\")","key":"DRK50NQHQc"},{"type":"outputs","id":"18QnJAzYhP_o93jgQOjps","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stdout","text":"The symbolic integral of sin(x) * cos(x) over [0, 2π] is: 0\n"},"key":"Hk7f0EqNh7"}],"key":"s76a7JEugc"}],"key":"t4YFOxAf1s"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":3,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Visual solution","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Siys9RCvHD"}],"identifier":"visual-solution","label":"Visual solution","html_id":"visual-solution","implicit":true,"key":"UjfBO3hL67"}],"key":"UCaN48lYPv"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def plot_orthogonality():\n    '''Defining functions to encampuslate code is a good habit'''\n\n    # Define the range of x values\n    x = np.linspace(0, 2 * np.pi, 1000)\n    \n    # Calculate sin(x) and cos(x)\n    y_sin = np.sin(x)\n    y_cos = np.cos(x)\n    \n    # Plotting sin(x) and cos(x)\n    plt.plot(x, y_sin, label='sin(x)')\n    plt.plot(x, y_cos, label='cos(x)')\n    \n    # Fill the area between two horizontal curves (optional)\n    plt.fill_between(x, y_sin * y_cos, alpha=0.3, color='gray', label='sin(x) * cos(x)')\n    \n    # Labels and title\n    plt.xlabel('x')\n    plt.ylabel('Function Value')\n    plt.title('Orthogonality of sin(x) and cos(x)')\n    plt.legend()\n    plt.grid(True)\n    plt.show()\n\n# Call the function\nplot_orthogonality()","key":"iSfc5wwVGn"},{"type":"outputs","id":"OvFpTsPfRMns9NjDYVox8","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{"image/png":{"width":588,"height":453}},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"1761cc8bf02173d1c41f8c08adab537d","path":"/Chem324/build/1761cc8bf02173d1c41f8c08adab537d.png"}}},"key":"s7W6JWMWja"}],"key":"qhPFhQjuBT"}],"key":"hFQlQ0E2Cb"}],"key":"TecQ8v7VjG"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Animations with Matplotlib","url":"/demo-animations","group":"Appendix B: Python and Scientific Computing"},"next":{"title":"Postulates of Quantum Mechanics","url":"/postulates-of-quantum-mechanics","group":"Appendix C: Postulates and Foundations"}}},"domain":"http://localhost:3000"}