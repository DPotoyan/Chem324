{"version":3,"kind":"Notebook","sha256":"327a56049c11ad9c7ff4d9dc1a3fce7775e61c25539b9989599df0762c148288","slug":"demo-quantum-waves","location":"/demos/09-demo-quantum-waves.md","dependencies":[],"frontmatter":{"title":"DEMO: Quantum Waves","kernelspec":{"name":"python3","display_name":"Python 3"},"content_includes_title":false,"authors":[{"nameParsed":{"literal":"Davit Potoyan","given":"Davit","family":"Potoyan"},"name":"Davit Potoyan","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/DPotoyan/Chem324","numbering":{"figure":{"enabled":true},"equation":{"enabled":true},"title":{"offset":1}},"math":{"\\bra":{"macro":"\\left\\langle #1 \\right|"},"\\ket":{"macro":"\\left| #1 \\right\\rangle"},"\\braket":{"macro":"\\left\\langle #1 \\right\\rangle"}},"source_url":"https://github.com/DPotoyan/Chem324/blob/main/demos/09-demo-quantum-waves.md","edit_url":"https://github.com/DPotoyan/Chem324/edit/main/demos/09-demo-quantum-waves.md","thumbnail":"/Chem324/build/colab-badge-a27fa23fd64b4102858cd5b410202f6a.svg","exports":[{"format":"md","filename":"09-demo-quantum-waves.md","url":"/Chem324/build/09-demo-quantum-wave-3ef33551022bb637de585e1b2195806a.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"link","url":"https://colab.research.google.com/github/DPotoyan/Chem324/blob/master/notebooks/demo-quantum-waves.ipynb","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"image","url":"/Chem324/build/colab-badge-a27fa23fd64b4102858cd5b410202f6a.svg","alt":"Open in Colab","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"QWPkFKlXQ8","urlSource":"../assets/colab-badge.svg"}],"urlSource":"https://colab.research.google.com/github/DPotoyan/Chem324/blob/master/notebooks/demo-quantum-waves.ipynb","key":"JxK5hJQt2E"}],"key":"VrbOUqGpQN"}],"key":"rjZO8IOj59"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nimport matplotlib.pyplot as plt\nfrom ipywidgets.widgets import interact, interactive\n\n%matplotlib inline\n%config InlineBackend.figure_format = 'retina'","key":"TD52HwOarg"},{"type":"outputs","id":"Piw7fpGaWpc6jKl56TOk1","children":[],"key":"NOkudWt4FY"}],"key":"VGEQywgCTg"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"Linear superspositions and time dependence","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"hJVnGoqueT"}],"identifier":"linear-superspositions-and-time-dependence","label":"Linear superspositions and time dependence","html_id":"linear-superspositions-and-time-dependence","implicit":true,"key":"fjAZA0eCuT"}],"key":"Ve8Ht9abKx"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def psi_n(x, n):\n    \"\"\"Time-independent wavefunction for a particle in a box.\"\"\"\n    L = 1 # set box length\n\n    return np.sqrt(2/L) * np.sin(n * np.pi * x / L)\n\ndef T_n(t, n):\n    \"\"\"Time dependence factor for the wavefunction.\"\"\"\n    L = 1 # set box length\n    m, hbar = 1, 1 # set atomic units\n    En = n**2 * np.pi**2 * hbar**2 / (2 * m * L**2)\n\n    return np.exp(-1j * En * t / hbar)\n\ndef psi_combined(x, t, L, c1=1, c2=1, n1=1, n2=2):\n    \"\"\"Time-dependent wavefunction for a linear superposition of two states of PIB\"\"\"\n\n    return c1 * psi_n(x, n1) * T_n(t, n1) + c2 * psi_n(x, n2) * T_n(t, n2)","key":"QcmrLdKP23"},{"type":"outputs","id":"hpM_lugIzAC_fDRu19Xr8","children":[],"key":"ej4bitHGO9"}],"key":"HtGPYUKsvq"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"children":[{"type":"text","value":"Plot time dependent quantum wavefunctions","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"AemoM9CAtL"}],"identifier":"plot-time-dependent-quantum-wavefunctions","label":"Plot time dependent quantum wavefunctions","html_id":"plot-time-dependent-quantum-wavefunctions","implicit":true,"key":"POhzTJlAJU"}],"key":"vCNZQXwsbz"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def plot_wavefunction(t=0, c1=1, c2=1, n1=1, n2=1):\n\n    L = 1.0\n    x = np.linspace(0, L, 1000)\n\n    psi_squared_x = np.abs(psi_combined(x, t, c1, c2, n1, n2))**2\n\n    plt.plot(x, psi_squared_x )\n\n    plt.title(f\"Probability density at t={t:.2f} with c1={c1:.2f} and c2={c2:.2f}\")\n    plt.xlabel('x')\n    plt.ylabel('$|\\Psi(x, t)|^2$')\n    plt.grid(True)\n    plt.ylim([0, 10])  # Adjust the y limit to suit the range of the probability density\n    plt.show()","key":"wBTZistALd"},{"type":"outputs","id":"mF1xf3TteexGYi6juc18R","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stderr","text":"<>:12: SyntaxWarning: invalid escape sequence '\\P'\n<>:12: SyntaxWarning: invalid escape sequence '\\P'\n/tmp/ipykernel_3238/2852754572.py:12: SyntaxWarning: invalid escape sequence '\\P'\n  plt.ylabel('$|\\Psi(x, t)|^2$')\n"},"key":"FWMm5XBf3X"}],"key":"T3Vi9egurA"}],"key":"gJ0i4YVZqw"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"plot_wavefunction(t=1, c1=1, c2=1, n1=1, n2=1)","key":"E8VdXlh8xO"},{"type":"outputs","id":"Pdcd1CyRWbp1zhLT0iodp","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{"image/png":{"width":565,"height":453}},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"0058fda886f43edb33378f8340771dac","path":"/Chem324/build/0058fda886f43edb33378f8340771dac.png"}}},"key":"K7ljx86DjE"}],"key":"vy1NgVOOW0"}],"key":"CN6sDGtrUh"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"interact(plot_wavefunction, t=(0, 10, 0.1), c1=(-1.5, 1.5, 0.1), c2=(-1.5, 1.5, 0.1), n1=(1,5), n2=(1,5))","key":"GQmb7qbZn5"},{"type":"outputs","id":"jAKFLzmd5aGV4R9lt0jEJ","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{"image/png":{"width":565,"height":453}},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"738136e71e78589812a09d60284e42a6","path":"/Chem324/build/738136e71e78589812a09d60284e42a6.png"}}},"key":"vqRkyGASFC"},{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"interactive(children=(FloatSlider(value=0.0, description='t', max=10.0), FloatSlider(value=1.0, description='c…","content_type":"text/plain"},"application/vnd.jupyter.widget-view+json":{"content":"{\"version_major\":2,\"version_minor\":0,\"model_id\":\"50ba0addd3f54779900ea3a9de7c50da\"}","content_type":"application/vnd.jupyter.widget-view+json"}}},"key":"Kbwv2zZ1BV"},{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":5,"metadata":{},"data":{"text/plain":{"content":"<function __main__.plot_wavefunction(t=0, c1=1, c2=1, n1=1, n2=1)>","content_type":"text/plain"}}},"key":"mxXm09Ptf7"}],"key":"uBSLvEtY72"}],"key":"GwP4I127tl"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"children":[{"type":"text","value":"Fourier Transforms","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"key":"C9yRQwgzEu"}],"identifier":"fourier-transforms","label":"Fourier Transforms","html_id":"fourier-transforms","implicit":true,"key":"IDDpVYzpxK"}],"key":"QcjGGYcZsf"},{"type":"block","kind":"notebook-code","children"