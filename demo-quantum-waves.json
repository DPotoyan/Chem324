{"version":3,"kind":"Notebook","sha256":"cdea2aa6f40416dabc0aefa3a3b688dcd0806cd68fc54c235a723b10fb5bf3c7","slug":"demo-quantum-waves","location":"/ch03/11-demo-quantum-waves.md","dependencies":[],"frontmatter":{"title":"DEMO: Quantum Waves","kernelspec":{"name":"python3","display_name":"Python 3"},"content_includes_title":false,"authors":[{"nameParsed":{"literal":"Davit Potoyan","given":"Davit","family":"Potoyan"},"name":"Davit Potoyan","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/DPotoyan/Chem324","numbering":{"figure":{"enabled":true},"equation":{"enabled":true},"title":{"offset":1}},"math":{"\\bra":{"macro":"\\left\\langle #1 \\right|"},"\\ket":{"macro":"\\left| #1 \\right\\rangle"},"\\braket":{"macro":"\\left\\langle #1 \\right\\rangle"}},"source_url":"https://github.com/DPotoyan/Chem324/blob/main/ch03/11-demo-quantum-waves.md","edit_url":"https://github.com/DPotoyan/Chem324/edit/main/ch03/11-demo-quantum-waves.md","exports":[{"format":"md","filename":"11-demo-quantum-waves.md","url":"/Chem324/build/11-demo-quantum-wave-eda18aea56cdb94cd54ddba6fbd581a0.md"}]},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nimport matplotlib.pyplot as plt\nfrom ipywidgets.widgets import interact, interactive\n\n%matplotlib inline\n%config InlineBackend.figure_format = 'retina'","key":"G6Wn0VeVMt"},{"type":"outputs","id":"TgjPXpjtEQmVThNPRao2l","children":[],"key":"fF4rIReuqd"}],"key":"NMNSv8sppJ"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"children":[{"type":"text","value":"Linear superspositions and time dependence","position":{"start":{"line":18,"column":1},"end":{"line":18,"column":1}},"key":"hM9y0GDqEI"}],"identifier":"linear-superspositions-and-time-dependence","label":"Linear superspositions and time dependence","html_id":"linear-superspositions-and-time-dependence","implicit":true,"key":"y9DDv971pt"}],"key":"sJD8wQ3q93"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def psi_n(x, n):\n    \"\"\"Time-independent wavefunction for a particle in a box.\"\"\"\n    L = 1 # set box length\n\n    return np.sqrt(2/L) * np.sin(n * np.pi * x / L)\n\ndef T_n(t, n):\n    \"\"\"Time dependence factor for the wavefunction.\"\"\"\n    L = 1 # set box length\n    m, hbar = 1, 1 # set atomic units\n    En = n**2 * np.pi**2 * hbar**2 / (2 * m * L**2)\n\n    return np.exp(-1j * En * t / hbar)\n\ndef psi_combined(x, t, L, c1=1, c2=1, n1=1, n2=2):\n    \"\"\"Time-dependent wavefunction for a linear superposition of two states of PIB\"\"\"\n\n    return c1 * psi_n(x, n1) * T_n(t, n1) + c2 * psi_n(x, n2) * T_n(t, n2)","key":"d75vUIT5O6"},{"type":"outputs","id":"tkJ1birPzwfqhKfymg6YK","children":[],"key":"aUeqOCf0Ef"}],"key":"RXgGygG2iU"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"children":[{"type":"text","value":"Plot time dependent quantum wavefunctions","position":{"start":{"line":41,"column":1},"end":{"line":41,"column":1}},"key":"LHZaPoZTH4"}],"identifier":"plot-time-dependent-quantum-wavefunctions","label":"Plot time dependent quantum wavefunctions","html_id":"plot-time-dependent-quantum-wavefunctions","implicit":true,"key":"Oc1z2oQhii"}],"key":"LrQ5avHPqn"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def plot_wavefunction(t=0, c1=1, c2=1, n1=1, n2=1):\n\n    L = 1.0\n    x = np.linspace(0, L, 1000)\n\n    psi_squared_x = np.abs(psi_combined(x, t, c1, c2, n1, n2))**2\n\n    plt.plot(x, psi_squared_x )\n\n    plt.title(f\"Probability density at t={t:.2f} with c1={c1:.2f} and c2={c2:.2f}\")\n    plt.xlabel('x')\n    plt.ylabel('$|\\Psi(x, t)|^2$')\n    plt.grid(True)\n    plt.ylim([0, 10])  # Adjust the y limit to suit the range of the probability density\n    plt.show()","key":"hCiardkoYl"},{"type":"outputs","id":"pIShStBPitijo5IYw1aqt","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stderr","text":"<>:12: SyntaxWarning: invalid escape sequence '\\P'\n<>:12: SyntaxWarning: invalid escape sequence '\\P'\n/tmp/ipykernel_3037/2852754572.py:12: SyntaxWarning: invalid escape sequence '\\P'\n  plt.ylabel('$|\\Psi(x, t)|^2$')\n"},"key":"RechHsqecY"}],"key":"gPr3gT1TT4"}],"key":"mhggH8kVRw"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"plot_wavefunction(t=1, c1=1, c2=1, n1=1, n2=1)","key":"YySnttvF0H"},{"type":"outputs","id":"U5W3B92GL6tDROOGcyudB","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{"image/png":{"width":565,"height":453}},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"0058fda886f43edb33378f8340771dac","path":"/Chem324/build/0058fda886f43edb33378f8340771dac.png"}}},"key":"ixWlAJajKh"}],"key":"RqK4RxznFA"}],"key":"ptgTFCftZ4"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"interact(plot_wavefunction, t=(0, 10, 0.1), c1=(-1.5, 1.5, 0.1), c2=(-1.5, 1.5, 0.1), n1=(1,5), n2=(1,5))","key":"ezU6Z1Mrod"},{"type":"outputs","id":"wwDiveUJJLNtOD827FIo3","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{"image/png":{"width":565,"height":453}},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"738136e71e78589812a09d60284e42a6","path":"/Chem324/build/738136e71e78589812a09d60284e42a6.png"}}},"key":"HmMHLmR9JP"},{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"in