{"version":3,"kind":"Notebook","sha256":"655e227680304630539666035bc7395d028202cdc88257bae9e48b8d5d4444b2","slug":"demo-quantum-waves","location":"/ch03/11-demo-quantum-waves.ipynb","dependencies":[],"frontmatter":{"title":"DEMO: Quantum Waves","content_includes_title":false,"kernelspec":{"name":"python3","display_name":"Python 3 (ipykernel)","language":"python"},"authors":[{"nameParsed":{"literal":"Davit Potoyan","given":"Davit","family":"Potoyan"},"name":"Davit Potoyan","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/DPotoyan/Chem324","numbering":{"figure":{"enabled":true},"equation":{"enabled":true},"title":{"offset":1}},"math":{"\\bra":{"macro":"\\left\\langle #1 \\right|"},"\\ket":{"macro":"\\left| #1 \\right\\rangle"},"\\braket":{"macro":"\\left\\langle #1 \\right\\rangle"}},"source_url":"https://github.com/DPotoyan/Chem324/blob/main/ch03/11-demo-quantum-waves.ipynb","edit_url":"https://github.com/DPotoyan/Chem324/edit/main/ch03/11-demo-quantum-waves.ipynb","exports":[{"format":"ipynb","filename":"11-demo-quantum-waves.ipynb","url":"/Chem324/build/11-demo-quantum-wave-6bb60841aae39d4ec88d8df730eb2797.ipynb"}]},"widgets":{},"mdast":{"type":"root","children":[{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nimport matplotlib.pyplot as plt\nfrom ipywidgets.widgets import interact, interactive\n\n%matplotlib inline\n%config InlineBackend.figure_format = 'retina'","key":"FM3YdUn0kn"},{"type":"outputs","id":"50dusthxmpxp_I0-uKL9s","children":[],"key":"CwXXNx1N3G"}],"key":"UeVXEOJ1iE"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Linear superspositions and time dependence","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"c2ZBQjIw2G"}],"identifier":"linear-superspositions-and-time-dependence","label":"Linear superspositions and time dependence","html_id":"linear-superspositions-and-time-dependence","implicit":true,"key":"jfZ29IMBnQ"}],"key":"eFp2iQSFkc"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def psi_n(x, n):\n    \"\"\"Time-independent wavefunction for a particle in a box.\"\"\"\n    L = 1 # set box length\n\n    return np.sqrt(2/L) * np.sin(n * np.pi * x / L)\n\ndef T_n(t, n):\n    \"\"\"Time dependence factor for the wavefunction.\"\"\"\n    L = 1 # set box length\n    m, hbar = 1, 1 # set atomic units\n    En = n**2 * np.pi**2 * hbar**2 / (2 * m * L**2)\n\n    return np.exp(-1j * En * t / hbar)\n\ndef psi_combined(x, t, L, c1=1, c2=1, n1=1, n2=2):\n    \"\"\"Time-dependent wavefunction for a linear superposition of two states of PIB\"\"\"\n\n    return c1 * psi_n(x, n1) * T_n(t, n1) + c2 * psi_n(x, n2) * T_n(t, n2)","key":"DvEYOwOBLs"},{"type":"outputs","id":"x4fAl1wXlnjLo4EHIPvkY","children":[],"key":"imHrEPSK8c"}],"key":"zpnvzyChBQ"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Plot time dependent quantum wavefunctions","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"vm2nzCdh33"}],"identifier":"plot-time-dependent-quantum-wavefunctions","label":"Plot time dependent quantum wavefunctions","html_id":"plot-time-dependent-quantum-wavefunctions","implicit":true,"key":"n8WPuRcBnH"}],"key":"hu88pPAm6D"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def plot_wavefunction(t=0, c1=1, c2=1, n1=1, n2=1):\n\n    L = 1.0\n    x = np.linspace(0, L, 1000)\n\n    psi_squared_x = np.abs(psi_combined(x, t, c1, c2, n1, n2))**2\n\n    plt.plot(x, psi_squared_x )\n\n    plt.title(f\"Probability density at t={t:.2f} with c1={c1:.2f} and c2={c2:.2f}\")\n    plt.xlabel('x')\n    plt.ylabel('$|\\Psi(x, t)|^2$')\n    plt.grid(True)\n    plt.ylim([0, 10])  # Adjust the y limit to suit the range of the probability density\n    plt.show()","key":"WXkTIGCUrf"},{"type":"outputs","id":"X3KPGo210qKtIAA1ho5FD","children":[],"key":"hqRh9PpNFo"}],"key":"r1XZ1Vof5W"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"plot_wavefunction(t=1, c1=1, c2=1, n1=1, n2=1)","key":"ZPZQNoT6TZ"},{"type":"outputs","id":"erW5Z5MnDCv6hhpHEPN1L","children":[],"key":"T5m67XncdO"}],"key":"hEEKd6nk3O"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"interact(plot_wavefunction, t=(0, 10, 0.1), c1=(-1.5, 1.5, 0.1), c2=(-1.5, 1.5, 0.1), n1=(1,5), n2=(1,5))","key":"P1yRX99Sv6"},{"type":"outputs","id":"sl-DWj-BCyL07vJOOuJf2","children":[],"key":"I2KOUg7ROe"}],"key":"x6kZpvob2u"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Fourier Transforms","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"k2OZtjwUCu"}],"identifier":"fourier-transforms","label":"Fourier Transforms","html_id":"fourier-transforms","implicit":true,"key":"LdblCVObp5"}],"key":"YDaHy5PCrf"}],"key":"ANmbV3lQTg"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"DEMO: Particle in a box","url":"/demo-particle-in-a-box","group":"Chapter 3: The Schrödinger Equation"},"next":{"title":"DEMO: Bonus challenge","url":"/demo-bonus-quantum-waves","group":"Chapter 3: The Schrödinger Equation"}}},"domain":"http://localhost:3000"}