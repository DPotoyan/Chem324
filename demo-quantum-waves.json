{"version":3,"kind":"Notebook","sha256":"327a56049c11ad9c7ff4d9dc1a3fce7775e61c25539b9989599df0762c148288","slug":"demo-quantum-waves","location":"/ch03/11-demo-quantum-waves.md","dependencies":[],"frontmatter":{"title":"DEMO: Quantum Waves","kernelspec":{"name":"python3","display_name":"Python 3"},"content_includes_title":false,"authors":[{"nameParsed":{"literal":"Davit Potoyan","given":"Davit","family":"Potoyan"},"name":"Davit Potoyan","id":"contributors-myst-generated-uid-0"}],"github":"https://github.com/DPotoyan/Chem324","numbering":{"figure":{"enabled":true},"equation":{"enabled":true},"title":{"offset":1}},"math":{"\\bra":{"macro":"\\left\\langle #1 \\right|"},"\\ket":{"macro":"\\left| #1 \\right\\rangle"},"\\braket":{"macro":"\\left\\langle #1 \\right\\rangle"}},"source_url":"https://github.com/DPotoyan/Chem324/blob/main/ch03/11-demo-quantum-waves.md","edit_url":"https://github.com/DPotoyan/Chem324/edit/main/ch03/11-demo-quantum-waves.md","thumbnail":"/Chem324/build/colab-badge-c03b7d8d10ff114cf1615c94fb35a2d0.svg","exports":[{"format":"md","filename":"11-demo-quantum-waves.md","url":"/Chem324/build/11-demo-quantum-wave-f82546b590aa414acda6f76a38ee1005.md"}]},"mdast":{"type":"root","children":[{"type":"block","children":[{"type":"paragraph","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"link","url":"https://colab.research.google.com/github/DPotoyan/Chem324/blob/master/notebooks/demo-quantum-waves.ipynb","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"children":[{"type":"image","url":"/Chem324/build/colab-badge-c03b7d8d10ff114cf1615c94fb35a2d0.svg","alt":"Open in Colab","position":{"start":{"line":9,"column":1},"end":{"line":9,"column":1}},"key":"DBhhFwdPwj","urlSource":"../assets/colab-badge.svg"}],"urlSource":"https://colab.research.google.com/github/DPotoyan/Chem324/blob/master/notebooks/demo-quantum-waves.ipynb","key":"TtYm80f8c0"}],"key":"qQgvLyZht8"}],"key":"xmuDPD7Qt0"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nimport matplotlib.pyplot as plt\nfrom ipywidgets.widgets import interact, interactive\n\n%matplotlib inline\n%config InlineBackend.figure_format = 'retina'","key":"dHHRQb3Tu3"},{"type":"outputs","id":"99waJo8aqfuYC4Oe5dQbR","children":[],"key":"yhHJoGeyTu"}],"key":"SdOznUIDM6"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"children":[{"type":"text","value":"Linear superspositions and time dependence","position":{"start":{"line":21,"column":1},"end":{"line":21,"column":1}},"key":"YqRj0IlL1N"}],"identifier":"linear-superspositions-and-time-dependence","label":"Linear superspositions and time dependence","html_id":"linear-superspositions-and-time-dependence","implicit":true,"key":"wPMtkhyJdM"}],"key":"DB3iQUcZVr"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def psi_n(x, n):\n    \"\"\"Time-independent wavefunction for a particle in a box.\"\"\"\n    L = 1 # set box length\n\n    return np.sqrt(2/L) * np.sin(n * np.pi * x / L)\n\ndef T_n(t, n):\n    \"\"\"Time dependence factor for the wavefunction.\"\"\"\n    L = 1 # set box length\n    m, hbar = 1, 1 # set atomic units\n    En = n**2 * np.pi**2 * hbar**2 / (2 * m * L**2)\n\n    return np.exp(-1j * En * t / hbar)\n\ndef psi_combined(x, t, L, c1=1, c2=1, n1=1, n2=2):\n    \"\"\"Time-dependent wavefunction for a linear superposition of two states of PIB\"\"\"\n\n    return c1 * psi_n(x, n1) * T_n(t, n1) + c2 * psi_n(x, n2) * T_n(t, n2)","key":"YRblQlIQEk"},{"type":"outputs","id":"qgZXltP0PcM0EA_OLNwVn","children":[],"key":"jAJUL0aaNj"}],"key":"jXTFvhg2j8"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"children":[{"type":"text","value":"Plot time dependent quantum wavefunctions","position":{"start":{"line":44,"column":1},"end":{"line":44,"column":1}},"key":"nrDsoKO4tV"}],"identifier":"plot-time-dependent-quantum-wavefunctions","label":"Plot time dependent quantum wavefunctions","html_id":"plot-time-dependent-quantum-wavefunctions","implicit":true,"key":"RLRC9YWVoL"}],"key":"ECNk5ezGjO"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def plot_wavefunction(t=0, c1=1, c2=1, n1=1, n2=1):\n\n    L = 1.0\n    x = np.linspace(0, L, 1000)\n\n    psi_squared_x = np.abs(psi_combined(x, t, c1, c2, n1, n2))**2\n\n    plt.plot(x, psi_squared_x )\n\n    plt.title(f\"Probability density at t={t:.2f} with c1={c1:.2f} and c2={c2:.2f}\")\n    plt.xlabel('x')\n    plt.ylabel('$|\\Psi(x, t)|^2$')\n    plt.grid(True)\n    plt.ylim([0, 10])  # Adjust the y limit to suit the range of the probability density\n    plt.show()","key":"qGoMZz9Qa6"},{"type":"outputs","id":"4toFr6K9RiO9q5vq6B_p1","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"stream","name":"stderr","text":"<>:12: SyntaxWarning: invalid escape sequence '\\P'\n<>:12: SyntaxWarning: invalid escape sequence '\\P'\n/tmp/ipykernel_3238/2852754572.py:12: SyntaxWarning: invalid escape sequence '\\P'\n  plt.ylabel('$|\\Psi(x, t)|^2$')\n"},"key":"SwYT1n3WQu"}],"key":"jhUO8IFQCr"}],"key":"yyTPse08r8"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"plot_wavefunction(t=1, c1=1, c2=1, n1=1, n2=1)","key":"VKaunjNQ85"},{"type":"outputs","id":"tAEiUZCYMwPHGmPQk0IQ0","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{"image/png":{"width":565,"height":453}},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"0058fda886f43edb33378f8340771dac","path":"/Chem324/build/0058fda886f43edb33378f8340771dac.png"}}},"key":"pI92oE3hH6"}],"key":"ofCu3xQR8U"}],"key":"MEIwJKfFGH"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"interact(plot_wavefunction, t=(0, 10, 0.1), c1=(-1.5, 1.5, 0.1), c2=(-1.5, 1.5, 0.1), n1=(1,5), n2=(1,5))","key":"btb8DOBujq"},{"type":"outputs","id":"JRHheeOfMxJmSjhPLuRt3","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{"image/png":{"width":565,"height":453}},"data":{"text/plain":{"content":"<Figure size 640x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"738136e71e78589812a09d60284e42a6","path":"/Chem324/build/738136e71e78589812a09d60284e42a6.png"}}},"key":"Fk4Oz6cLEi"},{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"interactive(children=(FloatSlider(value=0.0, description='t', max=10.0), FloatSlider(value=1.0, description='c…","content_type":"text/plain"},"application/vnd.jupyter.widget-view+json":{"content":"{\"version_major\":2,\"version_minor\":0,\"model_id\":\"50ba0addd3f54779900ea3a9de7c50da\"}","content_type":"application/vnd.jupyter.widget-view+json"}}},"key":"uBPMSutouH"},{"type":"output","children":[],"jupyter_data":{"output_type":"execute_result","execution_count":5,"metadata":{},"data":{"text/plain":{"content":"<function __main__.plot_wavefunction(t=0, c1=1, c2=1, n1=1, n2=1)>","content_type":"text/plain"}}},"key":"UzDRx2jJ86"}],"key":"Sx4DDskLhw"}],"key":"YDPfTk0eff"},{"type":"block","children":[{"type":"heading","depth":2,"position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"children":[{"type":"text","value":"Fourier Transforms","position":{"start":{"line":72,"column":1},"end":{"line":72,"column":1}},"key":"eV77vTSyw4"}],"identifier":"fourier-transforms","label":"Fourier Transforms","html_id":"fourier-transforms","implicit":true,"key":"Q8zFbIf8ez"}],"key":"HgVHti05YJ"},{"type":"block","kind":"notebook-code","children":[{