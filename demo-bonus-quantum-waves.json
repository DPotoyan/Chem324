a0xIk4srbbhj3fD2","children":[],"key":"OhXNix0OvR"}],"key":"qM4BzoHRb4"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Create a Gaussian pulse\ny3 = np.exp(-(x-np.pi)**2/0.1)\n\n# Compute Fourier transform\nY3 = np.fft.fft(y3)\n\n# Plot\nplt.figure(figsize=(12, 5))\nplt.subplot(1, 2, 1)\nplt.plot(x, y3)\nplt.title('Gaussian Pulse')\nplt.xlabel('Time')\nplt.ylabel('Amplitude')\n\nplt.subplot(1, 2, 2)\nplt.plot(frequencies, np.abs(Y3))\nplt.title('Fourier Transform')\nplt.xlabel('Frequency')\nplt.ylabel('Magnitude')\nplt.tight_layout()\nplt.show()","key":"qRCwWgQHmk"},{"type":"outputs","id":"M-DTTRWs4lW-wY9r2F6Rj","children":[],"key":"qz0JtnBYmZ"}],"key":"cokBsojyQ3"}],"key":"FlZgYsUdy5"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"DEMO: Quantum Waves","url":"/demo-quantum-waves","group":"Chapter 3: The Schrödinger Equation"},"next":{"title":"4. Model Systems","url":"/index-4","group":"Chapter 4: Model Systems"}}},"domain":"http://localhost:3000"}