LgyHw_px093dx5CG","children":[],"key":"Lu8bd3mBc9"}],"key":"kj2oIEjuqR"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Create a Gaussian pulse\ny3 = np.exp(-(x-np.pi)**2/0.1)\n\n# Compute Fourier transform\nY3 = np.fft.fft(y3)\n\n# Plot\nplt.figure(figsize=(12, 5))\nplt.subplot(1, 2, 1)\nplt.plot(x, y3)\nplt.title('Gaussian Pulse')\nplt.xlabel('Time')\nplt.ylabel('Amplitude')\n\nplt.subplot(1, 2, 2)\nplt.plot(frequencies, np.abs(Y3))\nplt.title('Fourier Transform')\nplt.xlabel('Frequency')\nplt.ylabel('Magnitude')\nplt.tight_layout()\nplt.show()","key":"kgJWzEgesZ"},{"type":"outputs","id":"nHW4Bwfeef8282O8cqWgl","children":[],"key":"hxX0qCATS2"}],"key":"gchT9ONFKg"}],"key":"dvyxhLeFmF"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"DEMO: Quantum Waves","url":"/demo-quantum-waves","group":"Chapter 3: The Schrödinger Equation"},"next":{"title":"4. Model Systems","url":"/index-4","group":"Chapter 4: Model Systems"}}},"domain":"http://localhost:3000"}