)\nplt.ylabel('Amplitude')\n\nplt.subplot(1, 2, 2)\nplt.plot(frequencies, np.abs(Y))\nplt.title('Fourier Transform')\nplt.xlabel('Frequency')\nplt.ylabel('Magnitude')\nplt.tight_layout()\nplt.show()","key":"KtLqCUntxq"},{"type":"outputs","id":"d_rIE5T9CKkUCIVuXQLqy","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{"image/png":{"width":1189,"height":489}},"data":{"text/plain":{"content":"<Figure size 1200x500 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"d493d1e64a8c226c50ff6b9217751ea5","path":"/Chem324/build/d493d1e64a8c226c50ff6b9217751ea5.png"}}},"key":"dU0l4Bz5WK"}],"key":"fya3RlwHxR"}],"key":"h9sjmzjUb4"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Create a Gaussian pulse\ny3 = np.exp(-(x-np.pi)**2/0.1)\n\n# Compute Fourier transform\nY3 = np.fft.fft(y3)\n\n# Plot\nplt.figure(figsize=(12, 5))\nplt.subplot(1, 2, 1)\nplt.plot(x, y3)\nplt.title('Gaussian Pulse')\nplt.xlabel('Time')\nplt.ylabel('Amplitude')\n\nplt.subplot(1, 2, 2)\nplt.plot(frequencies, np.abs(Y3))\nplt.title('Fourier Transform')\nplt.xlabel('Frequency')\nplt.ylabel('Magnitude')\nplt.tight_layout()\nplt.show()","key":"e25CTSgFfZ"},{"type":"outputs","id":"OkCd1CnHAve4I1gjl1T0x","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{"image/png":{"width":1190,"height":489}},"data":{"text/plain":{"content":"<Figure size 1200x500 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"0f3ee4e48ac7b4fdff4d3aebf5a7538b","path":"/Chem324/build/0f3ee4e48ac7b4fdff4d3aebf5a7538b.png"}}},"key":"tQYkm6DtEj"}],"key":"c7y6mUJwVY"}],"key":"DfXjS2lD6g"}],"key":"neGTP1Sdh5"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"DEMO: Quantum Waves","url":"/demo-quantum-waves","group":"Chapter 3: The Schrödinger Equation"},"next":{"title":"DEMO: N