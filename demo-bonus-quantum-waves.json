KRLUMBc3OiqY8ZWr","children":[],"key":"gm0ERLgv8n"}],"key":"eoeCmrYWun"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Create a Gaussian pulse\ny3 = np.exp(-(x-np.pi)**2/0.1)\n\n# Compute Fourier transform\nY3 = np.fft.fft(y3)\n\n# Plot\nplt.figure(figsize=(12, 5))\nplt.subplot(1, 2, 1)\nplt.plot(x, y3)\nplt.title('Gaussian Pulse')\nplt.xlabel('Time')\nplt.ylabel('Amplitude')\n\nplt.subplot(1, 2, 2)\nplt.plot(frequencies, np.abs(Y3))\nplt.title('Fourier Transform')\nplt.xlabel('Frequency')\nplt.ylabel('Magnitude')\nplt.tight_layout()\nplt.show()","key":"PflV1WjaVm"},{"type":"outputs","id":"c1W8P-wIlnt9lJzK2aEn5","children":[],"key":"MWMHY8ssZp"}],"key":"WDc5zvqFUT"}],"key":"zhuRrqEVhc"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"DEMO: Quantum Waves","url":"/demo-quantum-waves","group":"Chapter 3: The Schrödinger Equation"},"next":{"title":"Molecular Degrees of Freedom","url":"/molecular-degrees-of-freedom","group":"Chapter 4: Model Systems"}}},"domain":"http://localhost:3000"}