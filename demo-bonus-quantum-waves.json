xecutable":true,"value":"# Create a sine wave\nx = np.linspace(0, 2*np.pi, 1000)\ny = np.sin(5*x)\n\n# Compute Fourier transform\nY = np.fft.fft(y)\nfrequencies = np.fft.fftfreq(len(Y))\n\n# Plot\nplt.figure(figsize=(12, 5))\nplt.subplot(1, 2, 1)\nplt.plot(x, y)\nplt.title('Sine Wave')\nplt.xlabel('Time')\nplt.ylabel('Amplitude')\n\nplt.subplot(1, 2, 2)\nplt.plot(frequencies, np.abs(Y))\nplt.title('Fourier Transform')\nplt.xlabel('Frequency')\nplt.ylabel('Magnitude')\nplt.tight_layout()\nplt.show()","key":"PmVn3fGQKx"},{"type":"outputs","id":"eFfBmGvG-4ZGdSu4hgco0","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{"image/png":{"width":1189,"height":489}},"data":{"text/plain":{"content":"<Figure size 1200x500 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"d493d1e64a8c226c50ff6b9217751ea5","path":"/Chem324/build/d493d1e64a8c226c50ff6b9217751ea5.png"}}},"key":"vkbni92PF1"}],"key":"EvSU6nQu0A"}],"key":"zvgjDVYLiu"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Create a Gaussian pulse\ny3 = np.exp(-(x-np.pi)**2/0.1)\n\n# Compute Fourier transform\nY3 = np.fft.fft(y3)\n\n# Plot\nplt.figure(figsize=(12, 5))\nplt.subplot(1, 2, 1)\nplt.plot(x, y3)\nplt.title('Gaussian Pulse')\nplt.xlabel('Time')\nplt.ylabel('Amplitude')\n\nplt.subplot(1, 2, 2)\nplt.plot(frequencies, np.abs(Y3))\nplt.title('Fourier Transform')\nplt.xlabel('Frequency')\nplt.ylabel('Magnitude')\nplt.tight_layout()\nplt.show()","key":"f8pNCMbTq9"},{"type":"outputs","id":"1XtdcqZUYXS2r66xhX3oF","children":[{"type":"output","children":[],"jupyter_data":{"output_type":"display_data","metadata":{"image/png":{"width":1190,"height":489}},"data":{"text/plain":{"content":"<Figure size 1200x500 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"0f3ee4e48ac7b4fdff4d3aebf5a7538b","path":"/Chem324/build/0f3ee4e48ac7b4fdff4d3aebf