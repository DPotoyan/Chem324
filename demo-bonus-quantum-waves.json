vcuAx7y2JoWi9z8p","children":[],"key":"UTHRMM132B"}],"key":"zVVR89mjjS"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# Create a Gaussian pulse\ny3 = np.exp(-(x-np.pi)**2/0.1)\n\n# Compute Fourier transform\nY3 = np.fft.fft(y3)\n\n# Plot\nplt.figure(figsize=(12, 5))\nplt.subplot(1, 2, 1)\nplt.plot(x, y3)\nplt.title('Gaussian Pulse')\nplt.xlabel('Time')\nplt.ylabel('Amplitude')\n\nplt.subplot(1, 2, 2)\nplt.plot(frequencies, np.abs(Y3))\nplt.title('Fourier Transform')\nplt.xlabel('Frequency')\nplt.ylabel('Magnitude')\nplt.tight_layout()\nplt.show()","key":"ixwG7zObPS"},{"type":"outputs","id":"-x6vaeh9Dmkguk-KfCzYw","children":[],"key":"iJTm5j8Wjq"}],"key":"M9bVYXbqEZ"}],"key":"FSawAWIEkA"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"DEMO: Quantum Waves","url":"/demo-quantum-waves","group":"Chapter 3: The Schrödinger Equation"},"next":{"title":"DEMO: Numerical Schrödinger Solver","url":"/demo-numerical-schrodinger","group":"Chapter 3: The Schrödinger Equation"}}},"domain":"http://localhost:3000"}