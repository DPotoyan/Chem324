.pi, 128),\n                              blit=True)\nani","key":"uvtjhO7GPk"},{"type":"outputs","id":"lZWagADi5k2Wt5bKd91Qc","children":[],"key":"FkYZd28KSc"}],"key":"kEm8IACXZg"}],"key":"viF7NSkiB7"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Visualizing the Particle in a Box","url":"/demo-particle-in-a-box-1","group":"Appendix B: Python and Scientific Computing"},"next":{"title":"Cookbook of Worked Examples","url":"/cookbook","group":"Appendix B: Python and Scientific Computing"}}},"domain":"http://localhost:3000"}