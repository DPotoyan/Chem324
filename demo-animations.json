 are\n# initially empty, and will be given new values for each frame in the animation.\n#Note the commas! that is because ax.plot returns a list of 2D line objects\ntxt_title = ax1.set_title('')\nline1, = ax1.plot([], [], 'b', lw=2)     \nline2, = ax1.plot([], [], 'r', lw=2)\npt1,   = ax2.plot([], [], 'g.', ms=20)\nline3, = ax2.plot([], [], 'y', lw=2)\n\nax1.legend(['sin','cos']);","key":"BlLmkEPTy4"},{"type":"outputs","id":"cpmsTkRU7UjFHVUfLMZ4m","children":[],"key":"qYN0zA6nHt"}],"key":"r1pC4AAv7M"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Step 2. Define a function to draw each frame","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"oXyHwBw1SF"}],"identifier":"step-2-define-a-function-to-draw-each-frame","label":"Step 2. Define a function to draw each frame","html_id":"step-2-define-a-function-to-draw-each-frame","implicit":true,"key":"c8eiHrXpop"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"The animiation function is a function you define to draw individual frames in the animation. The variable ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"bolaVJhlYj"},{"type":"inlineCode","value":"n","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"LYQ5crxCBj"},{"type":"text","value":" will be the frame number.  The function draws the frame by resetting the data values for the global objects ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"IWEzhCN9hF"},{"type":"inlineCode","value":"txt_title","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Vqlehe9kCQ"},{"type":"text","value":", ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Z3q3miwUiu"},{"type":"inlineCode","value":"line1","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"USfT0qp0Ok"},{"type":"text","value":", ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"KJ2DaUFQqa"},{"type":"inlineCode","value":"line2","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"SfBzc2BDLh"},{"type":"text","value":", ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"od7fwl8Tt2"},{"type":"inlineCode","value":"pt1","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"f25IP01XSy"},{"type":"text","value":", and ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"pzZMP2hzkT"},{"type":"inlineCode","value":"line3","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"St9j5aSxHX"},{"type":"text","value":" that were defined above.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ikkj0Afpz1"}],"key":"sV0o6qj4qb"}],"key":"VizWORGQEf"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# animation function. This is called sequentially\ndef drawframe(n):\n    \n    x = np.linspace(0, 2, 1000)\n    y1 = np.sin(2 * np.pi * (x - 0.01 * n))\n    y2 = np.cos(2 * np.pi * (x - 0.01 * n))\n    line1.set_data(x, y1)\n    line2.set_data(x, y2)\n    line3.set_data(y1[0:50],y2[0:50])\n    pt1.set_data(y1[0],y2[0])\n    txt_title.set_text('Frame = {0:4d}'.format(n))\n    \n    return (line1,line2) #once line1 and line2 updated other global objects update too","key":"LOPxIAU1Xj"},{"type":"outputs","id":"DKvXAK6vva36TBJMLIl_v","children":[],"key":"irKBrstzrn"}],"key":"PDdoMvEEgn"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Step 3. Create the Animation Object","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Q2rDgOvrfD"}],"identifier":"step-3-create-the-animation-object","label":"Step 3. Create the Animation Object","html_id":"step-3-create-the-animation-object","implicit":true,"key":"C2LXlgaBgp"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"The animation class includes a function ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"mVvQRoWiwz"},{"type":"inlineCode","value":"FuncAnimation","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Ko0mosyw9d"},{"type":"text","value":" that incorporations a user-specified function to update the figure for each frame of the animation. The result is an animation object which is subsequently called to actually produce the desired animation.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"lZFxV2VQ0t"}],"key":"JbGUxOS7MW"}],"key":"Wixm617Wzz"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# blit=True re-draws only the parts that have changed.\nanim = animation.FuncAnimation(fig, \n                               drawframe, \n                               frames=100, \n                               interval=20, \n                               blit=True)\n\nanim","key":"zkCmGWdyvG"},{"type":"outputs","id":"5TxZYI4Rf4vfcP8PVLlrM","children":[],"key":"H5SW6lVVky"}],"key":"eN0sxUeMko"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, ax = plt.subplots()\nxdata, ydata = [], []\n\nln, = ax.plot([], [], 'ro')\nax.set_xlim(0, 2*np.pi)\nax.set_ylim(-1, 1);\n\ndef update(frame):\n    \n    xdata.append(frame)\n    ydata.append(np.sin(frame))\n    ln.set_data(xdata, ydata)\n    \n    return ln,\n\nani = animation.FuncAnimation(fig, \n                              update, \n                              frames=np.linspace(0, 2*np.pi, 128),\n                              blit=True)\nani","key":"g22LqHkcbp"},{"type":"outputs","id":"Gp0g5-H5waG-Wx3tOr-9Q","children":[],"key":"HWMC1WuTim"}],"key":"S7sVqL2wMS"}],"key":"oVJ0S5dG7k"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Visualizing the Particle in a Box","url":"/demo-particle-in-a-box-1","group":"Appendix B: Python and Scientific Computing"},"next":{"title":"Cookbook of Worked Examples","url":"/cookbook","group":"Appendix B: Python and Scientific Computing"}}},"domain":"http://localhost:3000"}