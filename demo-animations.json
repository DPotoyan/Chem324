 are\n# initially empty, and will be given new values for each frame in the animation.\n#Note the commas! that is because ax.plot returns a list of 2D line objects\ntxt_title = ax1.set_title('')\nline1, = ax1.plot([], [], 'b', lw=2)     \nline2, = ax1.plot([], [], 'r', lw=2)\npt1,   = ax2.plot([], [], 'g.', ms=20)\nline3, = ax2.plot([], [], 'y', lw=2)\n\nax1.legend(['sin','cos']);","key":"FLgaNnpu4H"},{"type":"outputs","id":"TALrfihs7R0iY1gR9e-8V","children":[],"key":"KuClknGt0K"}],"key":"pUHGeIqZWl"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Step 2. Define a function to draw each frame","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"PB4wrqpmnN"}],"identifier":"step-2-define-a-function-to-draw-each-frame","label":"Step 2. Define a function to draw each frame","html_id":"step-2-define-a-function-to-draw-each-frame","implicit":true,"key":"VsI8YM7WoZ"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"The animiation function is a function you define to draw individual frames in the animation. The variable ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"UzE1aJejgG"},{"type":"inlineCode","value":"n","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"wXDVM01ej2"},{"type":"text","value":" will be the frame number.  The function draws the frame by resetting the data values for the global objects ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"PhGztO2izI"},{"type":"inlineCode","value":"txt_title","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"pTC6w2FVMe"},{"type":"text","value":", ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"UHHQjL7COO"},{"type":"inlineCode","value":"line1","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"KlpLwAKvnA"},{"type":"text","value":", ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ZDu9dmlMDn"},{"type":"inlineCode","value":"line2","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"jqoNJy7IcV"},{"type":"text","value":", ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"ioluCVcR2h"},{"type":"inlineCode","value":"pt1","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"wSnL6WWMRy"},{"type":"text","value":", and ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"pVzv78Th9E"},{"type":"inlineCode","value":"line3","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"gjDWiZTqXQ"},{"type":"text","value":" that were defined above.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"hO1ZWUHPW3"}],"key":"FUOg7TaV22"}],"key":"K9yWueVx7Y"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# animation function. This is called sequentially\ndef drawframe(n):\n    \n    x = np.linspace(0, 2, 1000)\n    y1 = np.sin(2 * np.pi * (x - 0.01 * n))\n    y2 = np.cos(2 * np.pi * (x - 0.01 * n))\n    line1.set_data(x, y1)\n    line2.set_data(x, y2)\n    line3.set_data(y1[0:50],y2[0:50])\n    pt1.set_data(y1[0],y2[0])\n    txt_title.set_text('Frame = {0:4d}'.format(n))\n    \n    return (line1,line2) #once line1 and line2 updated other global objects update too","key":"Tdu0bbiGQQ"},{"type":"outputs","id":"J20zaDlmAjVpxYkHaFgf-","children":[],"key":"GMMbc63I2u"}],"key":"iykNSK6bTC"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Step 3. Create the Animation Object","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"zkf27zQwg1"}],"identifier":"step-3-create-the-animation-object","label":"Step 3. Create the Animation Object","html_id":"step-3-create-the-animation-object","implicit":true,"key":"DSSPhB5Zc2"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"The animation class includes a function ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"J1urM4HZkl"},{"type":"inlineCode","value":"FuncAnimation","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"bD6bJiSGDY"},{"type":"text","value":" that incorporations a user-specified function to update the figure for each frame of the animation. The result is an animation object which is subsequently called to actually produce the desired animation.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Iu6U9omcsQ"}],"key":"Oy5QpEjXck"}],"key":"haKlq8myJo"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# blit=True re-draws only the parts that have changed.\nanim = animation.FuncAnimation(fig, \n                               drawframe, \n                               frames=100, \n                               interval=20, \n                               blit=True)\n\nanim","key":"vtqRq0rC3Q"},{"type":"outputs","id":"qyGPwn8qxuxOpqzRLpdyZ","children":[],"key":"eGx6PSD57T"}],"key":"BBSgNSPT5m"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"fig, ax = plt.subplots()\nxdata, ydata = [], []\n\nln, = ax.plot([], [], 'ro')\nax.set_xlim(0, 2*np.pi)\nax.set_ylim(-1, 1);\n\ndef update(frame):\n    \n    xdata.append(frame)\n    ydata.append(np.sin(frame))\n    ln.set_data(xdata, ydata)\n    \n    return ln,\n\nani = animation.FuncAnimation(fig, \n                              update, \n                              frames=np.linspace(0, 2*np.pi, 128),\n                              blit=True)\nani","key":"EnvdapTbMh"},{"type":"outputs","id":"ogbkpsxSklWizL77NLlKl","children":[],"key":"sYe2mEZBYY"}],"key":"vwrmwgUGAR"}],"key":"K0WYLvNIhw"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Visualizing the Particle in a Box","url":"/demo-particle-in-a-box-1","group":"Appendix B: Python and Scientific Computing"},"next":{"title":"Cookbook of Worked Examples","url":"/cookbook","group":"Appendix B: Python and Scientific Computing"}}},"domain":"http://localhost:3000"}