 are\n# initially empty, and will be given new values for each frame in the animation.\n#Note the commas! that is because ax.plot returns a list of 2D line objects\ntxt_title = ax1.set_title('')\nline1, = ax1.plot([], [], 'b', lw=2)     \nline2, = ax1.plot([], [], 'r', lw=2)\npt1,   = ax2.plot([], [], 'g.', ms=20)\nline3, = ax2.plot([], [], 'y', lw=2)\n\nax1.legend(['sin','cos']);","key":"SIiyO0RPPl"},{"type":"outputs","id":"dQvcHmP6RfbrMYxQuVowN","children":[],"key":"ad0nbNfik5"}],"key":"EvSJB2QeSA"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Step 2. Define a function to draw each frame","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"MHv9cmxOpM"}],"identifier":"step-2-define-a-function-to-draw-each-frame","label":"Step 2. Define a function to draw each frame","html_id":"step-2-define-a-function-to-draw-each-frame","implicit":true,"key":"YFZ036yteq"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"The animiation function is a function you define to draw individual frames in the animation. The variable ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"tO4JNeNHXO"},{"type":"inlineCode","value":"n","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"E83WXSR2aH"},{"type":"text","value":" will be the frame number.  The function draws the frame by resetting the data values for the global objects ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"Oah65OM4O5"},{"type":"inlineCode","value":"txt_title","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"JSsCjxe8aD"},{"type":"text","value":", ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"lMlT1wtRq8"},{"type":"inlineCode","value":"line1","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"KbLVIsYscs"},{"type":"text","value":", ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"bHC3OeJFp9"},{"type":"inlineCode","value":"line2","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"EOq7pXE90u"},{"type":"text","value":", ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"DZLZWCtFED"},{"type":"inlineCode","value":"pt1","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"yb6JTrBZ5I"},{"type":"text","value":", and ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"W7wln0ShGO"},{"type":"inlineCode","value":"line3","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"CfYPUf5TSf"},{"type":"text","value":" that were defined above.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"JwAyEmCxHj"}],"key":"OjenY7WC1K"}],"key":"ZXkSEAgLQ5"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"# animation function. This is called sequentially\ndef drawframe(n):\n    \n    x = np.linspace(0, 2, 1000)\n    y1 = np.sin(2 * np.pi * (x - 0.01 * n))\n    y2 = np.cos(2 * np.pi * (x - 0.01 * n))\n    line1.set_data(x, y1)\n    line2.set_data(x, y2)\n    line3.set_data(y1[0:50],y2[0:50])\n    pt1.set_data(y1[0],y2[0])\n    txt_title.set_text('Frame = {0:4d}'.format(n))\n    \n    return (line1,line2) #once line1 and line2 updated other global objects update too","key":"jdHycbqhHH"},{"type":"outputs","id":"qRdEoVsWnYNyS6x7K-RE8","children":[],"key":"Vml1Kjetnp"}],"key":"I5cFWm50c9"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Step 3. Create the Animation Object","position":{"start":{"line":1,"column":1},"end":{"li