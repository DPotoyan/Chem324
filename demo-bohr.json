rite-a-function-to-make-calculations-easier","implicit":true,"key":"ex85RDZBej"}],"key":"vigw1rFtAL"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def rydberg_cm(n1, n2, Z=1):  # returns cm^-1\n\n    return R_H_cm * Z**2 * (1/n1**2 - 1/n2**2)","key":"OKfCT7Bfag"},{"type":"outputs","id":"Ux84MVxWYLFaPwfd4DiIh","children":[],"key":"H87bDVR05w"}],"key":"V4FCBDnqVX"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"","key":"wf9SO8u3oj"},{"type":"outputs","id":"1I9_Igtvd-750gwuC4jAp","children":[],"key":"UB2zqPXG9R"}],"key":"EIJjVYkXXV"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Plot sepctral transitions","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"LR0FXOQMXX"}],"identifier":"plot-sepctral-transitions","label":"Plot sepctral transitions","html_id":"plot-sepctral-transitions","implicit":true,"key":"TMkxjNCxWn"}],"key":"tXPXMafFgc"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"import numpy as np\nimport matplotlib.pyplot as plt\n\ndef plot_hydrogen_energy_levels(n_min=1, n_max=8):\n    n_vals = np.arange(n_min, n_max + 1)\n    E_eV = -13.6 / (n_vals ** 2)\n\n    fig, ax = plt.subplots(figsize=(6, 4))\n    for n, E in zip(n_vals, E_eV):\n        ax.hlines(E, 0, 1, linewidth=2)\n        ax.annotate(f\"n={n}\", xy=(1.01, E), xytext=(1.04, E),\n                    textcoords=\"data\", va=\"center\", fontsize=10)\n\n    ax.set_ylim(min(E_eV) - 0.5, 0.5)\n    ax.invert_yaxis()\n    ax.set_xlim(0, 1.2)\n    ax.set_xticks([])\n    ax.set_ylabel(\"Energy (eV)\")\n    ax.set_title(\"Bohr Energy Levels of Hydrogen\")\n    ax.axhline(0.0, linestyle=\"--\", linewidth=1)  # ionization limit\n    fig.tight_layout()\n    return fig, ax\n\nplot_hydrogen_energy_levels()\nplt.show()\n","key":"n6lrU7ECXt"},{"type":"outputs","id":"u0c9vhp9FKhnx--Ja8WhW","children":[],"key":"F6G9IpIGQ3"}],"key":"VZDGGy06O4"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Plot Black Body radiation curves","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"duoJWZ77jd"}],"identifier":"plot-black-body-radiation-curves","label":"Plot Black Body radiation curves","html_id":"plot-black-body-radiation-curves","implicit":true,"key":"qzM1owYBim"}],"key":"vlhJ5LVSl1"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"def planck(wavelength, T):\n    \"\"\"\n    Planck's Law to calculate the spectral radiance of black body radiation at temperature T.\n    \n    Parameters:\n    - wavelength (float): Wavelength in meters.\n    - T (float): Absolute temperature in Kelvin.\n    \n    Returns:\n    - (float): Spectral radiance in W/(m^2*sr*m).\n    \"\"\"\n   \n    exponent = (h*c) / (wavelength*k*T)\n    \n    exponent = np.clip(exponent, None, 700)  # Clip values of exponent at 700 to avoid numerical overflow\n\n    return (2.0*h*c**2) / (wavelength**5 * (np.exp(exponent) - 1))\n    \n\ndef plot_black_body(T, show=False):\n    \"\"\"\n    Plot the black body radiation spectrum for a given temperature T.\n    \"\"\"\n\n    # Lets pick some beautiful colors\n    from matplotlib import cm\n    from cycler import cycler\n    magma = cm.get_cmap('magma', 10)  # 10 discrete colors, feel free to change\n    plt.rcParams['axes.prop_cycle'] = cycler(color=[magma(i) for i in range(magma.N)])\n\n    wavelengths = np.linspace(1e-9, 5e-6, 1000)  # Wavelength range from 1 nm to 3 um\n    intensities = planck(wavelengths, T)\n    \n    plt.plot(wavelengths*1e9, intensities, label=f'T={T}', lw=3)  # Convert wavelength to nm for plotting\n    \n    plt.xlabel('Wavelength (nm)')\n    plt.ylabel('$Intensity (W/m^2)$')\n    plt.grid(True)\n    plt.legend()\n\n    max_int = max(planck(wavelengths, 5000)) # lets limit y axis to 5000\n    plt.ylim(0, max_int)\n\n    if show: # show is needed for interactive plots\n        plt.show() ","key":"ZnCjLerYye"},{"type":"outputs","id":"PFWHptCnX9f6_MJ2udLOW","children":[],"key":"DAbrxFTf8S"}],"key":"QplsjOX4uu"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"for T in range(3000, 5000, 200):\n    plot_black_body(T)","key":"VPn8N44ftn"},{"type":"outputs","id":"QWUSYFL4OZZPAFjoVMSYy","children":[],"key":"GdJy2olxGe"}],"key":"kC9wjVGtWA"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"from ipywidgets import interactive\n\ninteractive(plot_black_body, T=(1000, 5000, 100), show=True)","key":"olCo4P4RT1"},{"type":"outputs","id":"74xrIAyQpkatHPLcUjK91","children":[],"key":"DtPM8nZw6D"}],"key":"vEqp4FyrJb"},{"type":"block","kind":"notebook-content","children":[],"key":"Q0tDVT5Asq"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Dealing with complex numbers","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"Y7Yap32pjY"}],"identifier":"dealing-with-complex-numbers","label":"Dealing with complex numbers","html_id":"dealing-with-complex-numbers","implicit":true,"key":"URCalGa042"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"Consider the complex number ","position":{"start":{"line":3,"column":1},"end":{"line":3,"col