:1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mo stretchy=\"false\">[</mo><mn>0</mn><mo separator=\"true\">,</mo><mi>π</mi><mo stretchy=\"false\">]</mo></mrow><annotation encoding=\"application/x-tex\">[0, \\pi]</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mopen\">[</span><span class=\"mord\">0</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.03588em;\">π</span><span class=\"mclose\">]</span></span></span></span>","key":"CDyvfLtLgb"},{"type":"text","value":".","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"x25JabwWCX"}],"key":"elGXAG1LGz"}],"key":"yzQp3UFssn"}],"key":"VP7KOdg7F6"}],"key":"ZsRurxOz72"},{"type":"block","kind":"notebook-code","data":{"inputHidden":false,"outputHidden":false,"slideshow":{"slide_type":"slide"}},"children":[{"type":"code","lang":"python","executable":true,"value":"# Create 2D grid of angular variables\n\nphi = np.linspace(0, np.pi, 100)\ntheta = np.linspace(0, 2*np.pi, 100)\nphi, theta = np.meshgrid(phi, theta)\n\n# Convert to cartesian coordinates. r=const=1 for convenience\nx = np.sin(phi) * np.cos(theta)\ny = np.sin(phi) * np.sin(theta)\nz = np.cos(phi)","key":"fIcDPLLkSM"},{"type":"outputs","id":"cmlsaqy3I53Vt7Rn2WQs_","children":[],"key":"bGONSOu2jw"}],"key":"P2dRncDs10"},{"type":"block","kind":"notebook-code","data":{"inputHidden":false,"outputHidden":false,"slideshow":{"slide_type":"slide"}},"children":[{"type":"code","lang":"python","executable":true,"value":"fig = plt.figure(figsize=(10,10))\nax = fig.add_subplot(111, projection='3d')\n\nm, l = 4, 4\nYlm  = sph_harm(m, l, theta, phi).real\n\n#normalize color to [0,1] corresponding to magnitude of spherical harmonic\n\nfcolors = (Ylm - Ylm.min())/(Ylm.max() - Ylm.min())\n\nax.plot_surface(x, y, z, facecolors=cm.seismic(fcolors))\n\n# Turn off the axis planes\nax.set_axis_off()","key":"XQYxsRcX33"},{"type":"outputs","id":"z7caGbfq9BbSmo_gtREj4","children":[],"key":"T9ZcBV88T2"}],"key":"EVzV8I5L4K"},{"type":"block","kind":"notebook-code","data":{"slideshow":{"slide_type":"slide"}},"children":[{"type":"code","lang":"python","executable":true,"value":"@widgets.interact(l = np.arange(0,10,1),m=np.arange(-l,l+1,1))\n\ndef plot_SphHarm(l=1,m=0):\n\n    fig = plt.figure(figsize=(10,10))\n    ax = fig.add_subplot(111, projection='3d')\n\n    Ylm  = sph_harm(m, l, theta, phi).real\n\n    fcolors = (Ylm - Ylm.min())/(Ylm.max() - Ylm.min())\n\n    ax.plot_surface(x, y, z, facecolors=cm.seismic(fcolors))\n\n    ax.set_axis_off()\n    \n\n    # Set axes limit to keep aspect ratio 1:1:1\n    ax.set_xlim(-1, 1)\n    ax.set_ylim(-1, 1)\n    ax.set_zlim(-1, 1)","key":"KR0bJd4IBb"},{"type":"outputs","id":"y9iTna9e-Ht290aKxsfmJ","children":[],"key":"A83avK4aXF"}],"key":"S8APsE3aUL"},{"type":"block","kind":"notebook-content","data":{"slideshow":{"slide_type":"slide"}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Making volume plot with ipyvolumes","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"DPfxYi9e7v"}],"identifier":"making-volume-plot-with-ipyvolumes","label":"Making volume plot with ipyvolumes","html_id":"making-volume-plot-with-ipyvolumes","implicit":true,"key":"wzjwFzrXnu"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"https://ipyvolume.readthedocs.io/en/latest/index.html","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"IPyvolume","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"o8Xay9DWWd"}],"urlSource":"https://ipyvolume.readthedocs.io/en/latest/index.html","key":"aLj8VHxjHM"},{"type":"text","value":" is a Python library to visualize 3D volumes.","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"wq4x7oIZuZ"}],"key":"hcroeH3QZU"}],"key":"ROJUccXXng"}],"key":"ZkOLuJNwFD"}],"key":"MTz5SXUe93"},{"type":"block","kind":"notebook-code","data":{"slideshow":{"slide_type":"fragment"}},"children":[{"type":"code","lang":"python","executable":true,"value":"import ipyvolume as ipv","key":"hz9KmXy2ky"},{"type":"outputs","id":"KctLyQtWXVR3Af_Q12sqy","children":[],"key":"lMEr4xOtWR"}],"key":"p0edOTH8Qu"},{"type":"block","kind":"notebook-code","data":{"slideshow":{"slide_type":"slide"}},"children":[{"type":"code","lang":"python","executable":true,"value":"ipv.figure()\n\nm, l =  0, 1\n\nYlm  = sph_harm(m, l, theta, phi).real  \n\nfcolors = (Ylm - Ylm.min())/(Ylm.max() - Ylm.min())\n\nmesh = ipv.plot_surface(x, y, z, color=cm.seismic(fcolors))  # Feeding our x,y,z and colormap defined previously\n\nipv.show()","key":"ADT5d8fUDK"},{"type":"outputs","id":"cO5PzU8q2C_dBjsXT_5zy","children":[],"key":"HSfM2snfJp"}],"key":"gVKPg82xEz"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"ipv.show()","key":"h41yPG1PCc"},{"type":"outputs","id":"z74koxhbrHnjUJDiuIuUp","children":[],"key":"kcqRAOwPX2"}],"key":"mgGm6YP165"}],"key":"aNol3OtwHx"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"DEMO: H wavefunctions","url":"/demo-hydrogen-wavefunctions","group":"Chapter 5: The Hydrogen Atom"},"next":{"title":"Bonus: Atomic Orbitals","url":"/demo-bonus-atomic-orbitals","group":"Chapter 5: The Hydrogen Atom"}}},"domain":"http://localhost:3000"}