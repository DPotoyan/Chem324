:1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mo stretchy=\"false\">[</mo><mn>0</mn><mo separator=\"true\">,</mo><mi>π</mi><mo stretchy=\"false\">]</mo></mrow><annotation encoding=\"application/x-tex\">[0, \\pi]</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mopen\">[</span><span class=\"mord\">0</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.03588em;\">π</span><span class=\"mclose\">]</span></span></span></span>","key":"j4ofqP0aRL"},{"type":"text","value":".","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"lMTbqqIlYc"}],"key":"fjWvUObx1t"}],"key":"zMRJzvT9ZT"}],"key":"P2143DkbJT"}],"key":"YhjaOkUa1B"},{"type":"block","kind":"notebook-code","data":{"inputHidden":false,"outputHidden":false,"slideshow":{"slide_type":"slide"}},"children":[{"type":"code","lang":"python","executable":true,"value":"# Create 2D grid of angular variables\n\nphi = np.linspace(0, np.pi, 100)\ntheta = np.linspace(0, 2*np.pi, 100)\nphi, theta = np.meshgrid(phi, theta)\n\n# Convert to cartesian coordinates. r=const=1 for convenience\nx = np.sin(phi) * np.cos(theta)\ny = np.sin(phi) * np.sin(theta)\nz = np.cos(phi)","key":"IkrDFnnA6b"},{"type":"outputs","id":"hZ4XzheXfUYNoLG3KvkmK","children":[],"key":"wHaVOuRHhV"}],"key":"szRWamgkB4"},{"type":"block","kind":"notebook-code","data":{"inputHidden":false,"outputHidden":false,"slideshow":{"slide_type":"slide"}},"children":[{"type":"code","lang":"python","executable":true,"value":"fig = plt.figure(figsize=(10,10))\nax = fig.add_subplot(111, projection='3d')\n\nm, l = 4, 4\nYlm  = sph_harm(m, l, theta, phi).real\n\n#normalize color to [0,1] corresponding to magnitude of spherical harmonic\n\nfcolors = (Ylm - Ylm.min())/(Ylm.max() - Ylm.min())\n\nax.plot_surface(x, y, z, facecolors=cm.seismic(fcolors))\n\n# Turn off the axis planes\nax.set_axis_off()","key":"IuoK5ynJEh"},{"type":"outputs","id":"MtJxW6zUlZZ5dFSmFWREP","children":[],"key":"EKocyQVzYN"}],"key":"ZxScqovEjs"},{"type":"block","kind":"notebook-code","data":{"slideshow":{"slide_type":"slide"}},"children":[{"type":"code","lang":"python","executable":true,"value":"@widgets.interact(l = np.arange(0,10,1),m=np.arange(-l,l+1,1))\n\ndef plot_SphHarm(l=1,m=0):\n\n    fig = plt.figure(figsize=(10,10))\n    ax = fig.add_subplot(111, projection='3d')\n\n    Ylm  = sph_harm(m, l, theta, phi).real\n\n    fcolors = (Ylm - Ylm.min())/(Ylm.max() - Ylm.min())\n\n    ax.plot_surface(x, y, z, facecolors=cm.seismic(fcolors))\n\n    ax.set_axis_off()\n    \n\n    # Set axes limit to keep aspect ratio 1:1:1\n    ax.set_xlim(-1, 1)\n    ax.set_ylim(-1, 1)\n    ax.set_zlim(-1, 1)","key":"s1BoY34LEv"},{"type":"outputs","id":"j6GymijDci3NudUCDTpUc","children":[],"key":"BUYlCZ2NWF"}],"key":"CMVDsm7exN"},{"type":"block","kind":"notebook-content","data":{"slideshow":{"slide_type":"slide"}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Making volume plot with ipyvolumes","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"mRCzjFCxre"}],"identifier":"making-volume-plot-with-ipyvolumes","label":"Making volume plot with ipyvolumes","html_id":"making-volume-plot-with-ipyvolumes","implicit":true,"key":"wIv9m53Eyw"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"https://ipyvolume.readthedocs.io/en/latest/index.html","position":{"start":{"line":4,"col