:1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mo stretchy=\"false\">[</mo><mn>0</mn><mo separator=\"true\">,</mo><mi>π</mi><mo stretchy=\"false\">]</mo></mrow><annotation encoding=\"application/x-tex\">[0, \\pi]</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mopen\">[</span><span class=\"mord\">0</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.03588em;\">π</span><span class=\"mclose\">]</span></span></span></span>","key":"K3s2ae3BHG"},{"type":"text","value":".","position":{"start":{"line":12,"column":1},"end":{"line":12,"column":1}},"key":"g8OcOxQeen"}],"key":"JCVSXGkImV"}],"key":"pzj1eupmfL"}],"key":"eeWRJyvBXg"}],"key":"SfJqrVGOkS"},{"type":"block","kind":"notebook-code","data":{"inputHidden":false,"outputHidden":false,"slideshow":{"slide_type":"slide"}},"children":[{"type":"code","lang":"python","executable":true,"value":"# Create 2D grid of angular variables\n\nphi = np.linspace(0, np.pi, 100)\ntheta = np.linspace(0, 2*np.pi, 100)\nphi, theta = np.meshgrid(phi, theta)\n\n# Convert to cartesian coordinates. r=const=1 for convenience\nx = np.sin(phi) * np.cos(theta)\ny = np.sin(phi) * np.sin(theta)\nz = np.cos(phi)","key":"APbkYUhVlO"},{"type":"outputs","id":"-SqbD1M7my3pDyj6BqQIp","children":[],"key":"DJ6McDnwi8"}],"key":"ov5CNxY0o0"},{"type":"block","kind":"notebook-code","data":{"inputHidden":false,"outputHidden":false,"slideshow":{"slide_type":"slide"}},"children":[{"type":"code","lang":"python","executable":true,"value":"fig = plt.figure(figsize=(10,10))\nax = fig.add_subplot(111, projection='3d')\n\nm, l = 4, 4\nYlm  = sph_harm(m, l, theta, phi).real\n\n#normalize color to [0,1] corresponding to magnitude of spherical harmonic\n\nfcolors = (Ylm - Ylm.min())/(Ylm.max() - Ylm.min())\n\nax.plot_surface(x, y, z, facecolors=cm.seismic(fcolors))\n\n# Turn off the axis planes\nax.set_axis_off()","key":"v7SlcYXdLD"},{"type":"outputs","id":"9v3Pvr98DMRenZv7D2ERW","children":[],"key":"iSEVw6OYMl"}],"key":"SRb37jWFUP"},{"type":"block","kind":"notebook-code","data":{"slideshow":{"slide_type":"slide"}},"children":[{"type":"code","lang":"python","executable":true,"value":"@widgets.interact(l = np.arange(0,10,1),m=np.arange(-l,l+1,1))\n\ndef plot_SphHarm(l=1,m=0):\n\n    fig = plt.figure(figsize=(10,10))\n    ax = fig.add_subplot(111, projection='3d')\n\n    Ylm  = sph_harm(m, l, theta, phi).real\n\n    fcolors = (Ylm - Ylm.min())/(Ylm.max() - Ylm.min())\n\n    ax.plot_surface(x, y, z, facecolors=cm.seismic(fcolors))\n\n    ax.set_axis_off()\n    \n\n    # Set axes limit to keep aspect ratio 1:1:1\n    ax.set_xlim(-1, 1)\n    ax.set_ylim(-1, 1)\n    ax.set_zlim(-1, 1)","key":"qv3bewk4Ec"},{"type":"outputs","id":"kN7Y-FM9wjjjkS2AkSKGu","children":[],"key":"q9tSpm1zYW"}],"key":"uhekbpfVCK"},{"type":"block","kind":"notebook-content","data":{"slideshow":{"slide_type":"slide"}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Making volume plot with ipyvolumes","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"zYNgxLZHGw"}],"identifier":"making-volume-plot-with-ipyvolumes","label":"Making volume plot with ipyvolumes","html_id":"making-volume-plot-with-ipyvolumes","implicit":true,"key":"PHw7vYaGe4"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"https://ipyvolume.readthedocs.io/en/latest/index.html","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"text","value":"IPyvolume","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"cWFBRdcjaY"}],"urlSource":"https://ipyvolume.readthedocs.io/en/latest/index.html","key":"NcsGZgDDYh"},{"type":"text","value":" is a Python library to visualize 3D volumes.","position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"key":"IBQwq6mdkP"}],"key":"OaEfjGCOX9"}],"key":"yBg8XnIZl2"}],"key":"ljX8bm5tuh"}],"key":"y02Hjg1cOj"},{"type":"block","kind":"notebook-code","data":{"slideshow":{"slide_type":"fragment"}},"children":[{"type":"code","lang":"python","executable":true,"value":"import ipyvolume as ipv","key":"xZrXjB1PuJ"},{"type":"outputs","id":"znIpbaRv_YBYcavhDFHTz","children":[],"key":"THwXlxNzgw"}],"key":"hfXhSGVIin"},{"type":"block","kind":"notebook-code","data":{"slideshow":{"slide_type":"slide"}},"children":[{"type":"code","lang":"python","executable":true,"value":"ipv.figure()\n\nm, l =  0, 1\n\nYlm  = sph_harm(m, l, theta, phi).real  \n\nfcolors = (Ylm - Ylm.min())/(Ylm.max() - Ylm.min())\n\nmesh = ipv.plot_surface(x, y, z, color=cm.seismic(fcolors))  # Feeding our x,y,z and colormap defined previously\n\nipv.show()","key":"taK8XO63G4"},{"type":"outputs","id":"pviG39Mr5SOiUIQ-iByIH","children":[],"key":"yO3GwGgfBR"}],"key":"we9dkdPmAR"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"ipv.show()","key":"plOPcYIwdC"},{"type":"outputs","id":"A6uUGKrmkIXo8i9vzzVOg","children":[],"key":"VMbraPN2Ae"}],"key":"LMiSYHi6wu"}],"key":"y3ADvkIlWN"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"DEMO: H wavefunctions","url":"/demo-hydrogen-wavefunctions","group":"Chapter 5: The Hydrogen Atom"},"next":{"title":"Bonus: Atomic Orbitals","url":"/demo-bonus-atomic-orbitals","group":"Chapter 5: The Hydrogen Atom"}}},"domain":"http://localhost:3000"}