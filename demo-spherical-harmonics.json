onic\n\nfcolors = (Ylm - Ylm.min())/(Ylm.max() - Ylm.min())\n\nax.plot_surface(x, y, z, facecolors=cm.seismic(fcolors))\n\n# Turn off the axis planes\nax.set_axis_off()","key":"d5uMwCcYPl"},{"type":"outputs","id":"soWIVI1rGMyyO0GsDmn1o","children":[],"key":"IN1PtjIIYS"}],"key":"Gco1hIaJjN"},{"type":"block","kind":"notebook-code","data":{"slideshow":{"slide_type":"slide"}},"children":[{"type":"code","lang":"python","executable":true,"value":"@widgets.interact(l = np.arange(0,10,1),m=np.arange(-l,l+1,1))\n\ndef plot_SphHarm(l=1,m=0):\n\n    fig = plt.figure(figsize=(10,10))\n    ax = fig.add_subplot(111, projection='3d')\n\n    Ylm  = sph_harm(m, l, theta, phi).real\n\n    fcolors = (Ylm - Ylm.min())/(Ylm.max() - Ylm.min())\n\n    ax.plot_surface(x, y, z, facecolors=cm.seismic(fcolors))\n\n    ax.set_axis_off()\n    \n\n    # Set axes limit to keep aspect ratio 1:1:1\n    ax.set_xlim(-1, 1)\n    ax.set_ylim(-1, 1)\n    ax.set_zlim(-1, 1)","key":"BgpWRldpTf"},{"type":"outputs","id":"6uDuXMuJ9icLh5AX2WO3x","children":[],"key":"OnWkCSEsX0"}],"key":"e3GGEGcQWt"},{"type":"block","kind":"notebook-content","data":{"slideshow":{"slide_type":"slide"}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Making volume plot with ipyvolumes","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"LNGxw6XsH2"}],"identifier":"making-volume-plot-with-ipyvolumes","label":"Making volume plot with ipyvolumes","html_id":"making-volume-plot-with-ipyvolumes","implicit":true,"key":"IVbmHBkx1G"},{"type":"list","ordered":false,"spread":false,"position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"listItem","spread":true,"position":{"start":{"line":4,"column":1},"end":{"line":4,"column":1}},"children":[{"type":"paragraph","children":[{"type":"link","url":"https://ipyvolume.readthedocs.io/en/latest/index.html","position":{"start":{"line":4,"col