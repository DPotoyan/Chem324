# _build is a symlink (to ~/Library/Caches/chem324_build); also match Dropbox conflicted copies
_build*
.jupyter_cache/
# Python env for the build (jupyter-book-marimo plugin lives here)
.venv/
# Build cache written by the jupyter-book-marimo plugin
.jupyter-book-marimo/
**/.ipynb_checkpoints/
**/__pycache__/
.DS_Store
# AI tooling notes — kept local, not part of the published course
CLAUDE.md
# Quarto render artifacts (decks are regenerated from .qmd)
slides/**/*_files/
slides/**/*.html
slides/.quarto/
# cube files written by pyscf demos at build time
*.cube
