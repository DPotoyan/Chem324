qFzXQ2Tl"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":4,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Now lets package this into a nice little function so we can reuse it in animations!","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"JKTAtGtLfN"}],"identifier":"now-lets-package-this-into-a-nice-little-function-so-we-can-reuse-it-in-animations","label":"Now lets package this into a nice little function so we can reuse it in animations!","html_id":"now-lets-package-this-into-a-nice-little-function-so-we-can-reuse-it-in-animations","implicit":true,"key":"LEyHzFAQBW"}],"key":"V3Dx0E1UN1"},{"type":"block","kind":"notebook-code","data":{"slideshow":{"slide_type":"fragment"},"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"def wave1d(L=2):\n    \"\"\"\n    Plots a 1D sine wave with a specified wavelength.\n\n    Parameters:\n    L (float): Wavelength of the sine wave. Default is 2 units.\n\n    The function generates a sine wave of the form y = sin(2πx / L) and \n    plots it over the domain x = [0, 1]. The plot includes labeled axes, \n    a title, and a legend showing the value of L (wavelength).\n    \"\"\"\n    \n    # Generate 1000 points between 0 and 1 for the x-axis\n    x = np.linspace(0.0, 1.0, 1000)\n    \n    # Calculate the y-values based on the sine wave formula\n    y = np.sin(2 * np.pi * x / L)\n\n    # Create the plot\n    plt.plot(x, y, label=f'L = {L}')\n    \n    # Label the axes\n    plt.xlabel('x (position)')\n    plt.ylabel('y (amplitude)')\n    \n    # Add a title and legend\n    plt.title('1D Sine Wave')\n    plt.legend()\n    \n    # Set limits for the y-axis to improve clarity\n    plt.ylim(-1, 1)\n    \n    # Display the plot\n    plt.show()\n","visibility":"hide","key":"hbeyKLAe6O"},{"type":"outputs","id":"H9eHrb6ehrQvmzNHAf81y","children":[],"visibility":"show","key":"aaffm039BI"}],"vi