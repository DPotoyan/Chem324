lue":"y = sin(k(x - vt))","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>y</mi><mo>=</mo><mi>s</mi><mi>i</mi><mi>n</mi><mo stretchy=\"false\">(</mo><mi>k</mi><mo stretchy=\"false\">(</mo><mi>x</mi><mo>−</mo><mi>v</mi><mi>t</mi><mo stretchy=\"false\">)</mo><mo stretchy=\"false\">)</mo></mrow><annotation encoding=\"application/x-tex\">y = sin(k(x - vt))</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.625em;vertical-align:-0.1944em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.03588em;\">y</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">=</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord mathnormal\">s</span><span class=\"mord mathnormal\">in</span><span class=\"mopen\">(</span><span class=\"mord mathnormal\" style=\"margin-right:0.03148em;\">k</span><span class=\"mopen\">(</span><span class=\"mord mathnormal\">x</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mbin\">−</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.03588em;\">v</span><span class=\"mord mathnormal\">t</span><span class=\"mclose\">))</span></span></span></span>","key":"s4AeMWXNH6"},{"type":"text","value":" and ","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"x5GNoHUdEy"},{"type":"inlineMath","value":"y = sin(k(x - vt) + \\phi)","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>y</mi><mo>=</mo><mi>s</mi><mi>i</mi><mi>n</mi><mo stretchy=\"false\">(</mo><mi>k</mi><mo stretchy=\"false\">(</mo><mi>x</mi><mo>−</mo><mi>v</mi><mi>t</mi><mo stretchy=\"false\">)</mo><mo>+</mo><mi>ϕ</mi><mo stretchy=\"false\">)</mo></mrow><annotation encoding=\"application/x-tex\">y = sin(k(x - vt) + \\phi)</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.625em;vertical-align:-0.1944em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.03588em;\">y</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">=</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord mathnormal\">s</span><span class=\"mord mathnormal\">in</span><span class=\"mopen\">(</span><span class=\"mord mathnormal\" style=\"margin-right:0.03148em;\">k</span><span class=\"mopen\">(</span><span class=\"mord mathnormal\">x</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mbin\">−</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord mathnormal\" style=\"margin-right:0.03588em;\">v</span><span class=\"mord mathnormal\">t</span><span class=\"mclose\">)</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span><span class=\"mbin\">+</span><span class=\"mspace\" style=\"margin-right:0.2222em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord mathnormal\">ϕ</span><span class=\"mclose\">)</span></span></span></span>","key":"an2i3gaAnr"},{"type":"text","value":".","position":{"start":{"line":2,"column":1},"end":{"line":2,"column":1}},"key":"yEwJo0FzNs"}],"key":"FoJMdDbUSs"}],"key":"KHHn5QnFXc"},{"type":"listItem","spread":true,"position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"paragraph","children":[{"type":"text","value":"where ","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"R9DgWFG0BD"},{"type":"inlineMath","value":"\\phi","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"html":"<span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\"><semantics><mrow><mi>ϕ</mi></mrow><annotation encoding=\"application/x-tex\">\\phi</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.8889em;vertical-align:-0.1944em;\"></span><span class=\"mord mathnormal\">ϕ</span></span></span></span>","key":"YdSBkJugzh"},{"type":"text","value":" is the phase shift between the two. All three waveforms are plotted on the same graph.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"kZLkeUQIKz"}],"key":"hUQ5l975I6"}],"key":"mqKOSZ4gZE"}],"key":"lgyEGldpHq"}],"key":"Cwm2G7IJVY"},{"type":"block","kind":"notebook-code","data":{"slideshow":{"slide_type":"fragment"},"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"def wavef2(k=10, t=0, phi=0, v=1):\n    \"\"\"\n    Plots two traveling waves and their superposition.\n\n    Parameters:\n    k (float): Wave number (related to wavelength). Default is 10.\n    t (float): Time at which to evaluate the wave. Default is 0.\n    phi (float): Phase shift between the two waves. Default is 0.\n    v (float): Velocity of the waves. Positive velocity moves the wave to the right. \n               Try flipping the direction of velocity (negative v) to observe standing waves.\n    \"\"\"\n    \n    # Create 1000 points between 0 and 1 for the x-axis\n    x = np.linspace(0, 1., 1000)\n    \n    # Define the first traveling wave\n    wave1 = np.sin(k * (x - v * t)) \n    \n    # Define the second traveling wave with a phase shift\n    wave2 = np.sin(k * (x - v * t) + phi)  # Flip v to observe a standing wave effect\n    \n    # Plot the two individual waves and their superposition\n    plt.plot(x, wave1, lw=2, color='blue', label='Wave 1')\n    plt.plot(x, wave2, lw=2, color='green', label='Wave 2')\n    plt.plot(x, wave1 + wave2, lw=3, color='red', label='Wave 1 + Wave 2')\n    \n    # Set limits for the y-axis\n    plt.ylim([-2.5, 2.5])\n    \n    # Add a legend and grid for clarity\n    plt.legend()\n    plt.grid(True)\n    \n    # Display the plot\n    plt.show()","visibility":"hide","key":"bLlV3t9owC"},{"type":"outputs","id":"ioD7EBW9yyWWJXQZlh5T2","children":[],"visibility":"show","key":"NsMeKccOir"}],"visibility":"show","key":"dYTnFlig6q"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"interactive(wavef2, k=(2, 20), t=(0,50.0,0.1), phi=(0, 2*np.pi, np.pi/8),v=1)","key":"RMBMEdNPpn"},{"type":"outputs","id":"rekxquK8t_i5uuxqCAh9n","children":[],"key":"YQts9aFi4M"}],"key":"TpD1WEEpSL"},{"type":"block","kind":"notebook-code","data":{"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"#@title Animate traveling wave in 3D\n\ndef wave_x_t(A=1, k=1.0, omega=1, phi=0):\n    # Create a grid of x and t values\n    x = np.linspace(0, 2 * np.pi, 100)\n    t = np.linspace(0, 2 * np.pi, 100)\n    X, T = np.meshgrid(x, t)\n\n    # Calculate the wave amplitude for each combination of x and t\n    Y = A * np.sin(k * X - omega * T + phi)\n\n    # Create the figure\n    fig = go.Figure(\n        data=[go.Surface(z=Y, x=X, y=T, colorscale='Viridis')],\n        layout=go.Layout(\n            title='Traveling Wave Animation',\n            scene=dict(\n                xaxis_title='Position',\n                yaxis_title='Time',\n                zaxis_title='Amplitude',\n                camera_eye=dict(x=1.5, y=1.5, z=1.5),\n            ),\n            width=800,\n            height=800,\n            updatemenus=[dict(type='buttons', showactive=False,\n                              buttons=[dict(label='Play',\n                                             method='animate',\n                                             args=[None, dict(frame=dict(duration=50, redraw=True), \n                                                              mode='immediate')])])]\n        )\n    )\n\n    # Generate frames for the animation\n    frames = []\n    for phi in np.linspace(0, 2 * np.pi, 100):\n        Y = A * np.sin(k * X - omega * T + phi)\n        frames.append(go.Frame(data=[go.Surface(z=Y, x=X, y=T)], name=str(phi)))\n\n    fig.frames = frames\n\n    return fig\n\n# Generate and show the animation\nfig = wave_x_t(A=1, k=1.0, omega=1, phi=0)\nfig.show()","visibility":"hide","key":"ZNvHMgfCOB"},{"type":"outputs","id":"Av01bpJBcMyf9MFaEM_Ez","children":[],"visibility":"show","key":"I4CQVt8voC"}],"visibility":"show","key":"ug9F7ebzwA"},{"type":"block","kind":"notebook-content","data":{"slideshow":{"slide_type":"slide"}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Normal modes of 1D guitar string","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"a9Jf2ShF50"}],"identifier":"normal-modes-of-1d-guitar-string","label":"Normal modes of 1D guitar string","html_id":"normal-modes-of-1d-guitar-string","implicit":true,"key":"IU7qPQwBge"}],"key":"EN2Q0DVSm3"},{"type":"block","kind":"notebook-code","data":{"slideshow":{"slide_type":"fragment"},"tags":[]},"children":[{"type":"code","lang":"python","executable":true,"value":"def guitar1d(n=1, t=0):\n    \"\"\"\n    Visualizes the 1D normal mode of a vibrating guitar string at a specific time.\n\n    Parameters:\n    n (int): Mode number (harmonic) of the vibrating string. Default is 1.\n    t (float): Time at which to evaluate the normal mode. Default is 0.\n    \n    The function plots the displacement of the string at time t based on the \n    normal mode solution y(x, t) = sin(n * pi * x / L) * cos(omega * t), where\n    L is the length of the string (default is 1) and omega is the angular frequency.\n    \"\"\"\n    \n    # Constants\n    v = 1          # Wave speed\n    L = 1          # Length of the string\n    omega = np.pi * v / L  # Angular frequency for the fundamental mode (n=1)\n    \n    # Spatial grid from 0 to L\n    x = np.linspace(0, L, 1000)\n    \n    # Compute the displacement of the string for mode n and time t\n    y = np.sin(n * np.pi * x / L) * np.cos(omega * t)\n    \n    # Plot the displacement of the string\n    plt.plot(x, y, lw=3)\n    \n    # Add title, grid, and axis limits\n    plt.title(f'Normal Mode #{n} of a 1D Guitar String')\n    plt.grid(True, linestyle='--')\n    plt.ylim(-1, 1)\n    \n    # Label the axes\n    plt.xlabel('Position along string (x)')\n    plt.ylabel('Displacement (y)')\n    \n    # Display the plot\n    plt.show()","visibility":"hide","key":"iPjVeNpbVT"},{"type":"outputs","id":"-btNC4LYXuOls0_yr1hSX","children":[],"visibility":"show","key":"uDgvtXABCv"}],"visibility":"show","key":"cCkLYaaXXz"},{"type":"block","kind":"notebook-code","children":[{"type":"code","lang":"python","executable":true,"value":"interactive(guitar1d, n=(1,10), t=(0, 10, 0.1))","key":"FmRglG1QHa"},{"type":"outputs","id":"CSfNJPYpBzSeBp0LjBBOa","children":[],"key":"M3HiyUC88t"}],"key":"fMUotL07op"},{"type":"block","kind":"notebook-content","data":{"slideshow":{"slide_type":"slide"}},"children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"1D guitar vibrations as linear combination of normal modes","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"NaUX98NUI6"}],"identifier":"id-1d-guitar-vibrations-as-linear-combination-of-normal-modes","label":"1D guitar vibrations as linear combination of normal modes","html_id":"id-1d-guitar-vibrations-as-linear-combination-of-normal-modes","implicit":true,"key":"KifTWNdsjj"}],"key":"PAnxxEvy2Q"},{"type":"block","kind":"notebook-content","data":{"slideshow":{"slide_type":"-"}},"children":[{"type":"math","value":"u(x,t) = c_1 u_1 + c_2 u_2 +c_3 u_3 + ...","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"html":"<span class=\"katex-display\"><span class=\"katex\"><span class=\"katex-mathml\"><math xmlns=\"http://www.w3.org/1998/Math/MathML\" display=\"block\"><semantics><mrow><mi>u</mi><mo stretchy=\"false\">(</mo><mi>x</mi><mo separator=\"true\">,</mo><mi>t</mi><mo stretchy=\"false\">)</mo><mo>=</mo><msub><mi>c</mi><mn>1</mn></msub><msub><mi>u</mi><mn>1</mn></msub><mo>+</mo><msub><mi>c</mi><mn>2</mn></msub><msub><mi>u</mi><mn>2</mn></msub><mo>+</mo><msub><mi>c</mi><mn>3</mn></msub><msub><mi>u</mi><mn>3</mn></msub><mo>+</mo><mi mathvariant=\"normal\">.</mi><mi mathvariant=\"normal\">.</mi><mi mathvariant=\"normal\">.</mi></mrow><annotation encoding=\"application/x-tex\">u(x,t) = c_1 u_1 + c_2 u_2 +c_3 u_3 + ...</annotation></semantics></math></span><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:1em;vertical-align:-0.25em;\"></span><span class=\"mord mathnormal\">u</span><span class=\"mopen\">(</span><span class=\"mord mathnormal\">x</span><span class=\"mpunct\">,</span><span class=\"mspace\" style=\"margin-right:0.1667em;\"></span><span class=\"mord mathnormal\">t</span><span class=\"mclose\">)</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span><span class=\"mrel\">=</span><span class=\"mspace\" style=\"margin-right:0.2778em;\"></span></span><span class=\"base\"><span class=\"strut\" style=\"height:0.7333em;vertical-align:-0.15em;\"></span><span class=\"mord\"><span class=\"mord mathnormal\">c</span