, rotation=0)\nax.text(v[0]+0.1, v[1]+0.1, r'$\\mathbf{v} = 2\\mathbf{e_1} + 3\\mathbf{e_2}$', color='royalblue', fontsize=14)\n\n# Axes and labels\nax.axhline(0, color='black', lw=1)\nax.axvline(0, color='black', lw=1)\nax.set_xlabel('x')\nax.set_ylabel('y')\nax.set_title('A vector as a linear combination of basis vectors')\nplt.show()","key":"aiI6rzl3Rt"},{"type":"div","children":[{"type":"div","class":"output","children":[],"key":"NmBK4HLZgv"}],"key":"Ni17OlBIUB"}],"key":"iZQUK0xCTS"},{"type":"heading","depth":2,"children":[{"type":"text","value":"Vectors as arrays of numbers","key":"qKJDNWc7mf"}],"identifier":"vectors-as-arrays-of-numbers","label":"Vectors as arrays of numbers","html_id":"vectors-as-arrays-of-numbers","implicit":true,"key":"nQ7DsOmpnN"},{"type":"paragraph","children":[{"type":"text","value":"A ","key":"VNzeOPlft2"},{"type":"strong","children":[{"type":"text","value":"vector","key":"HD7rAzIjRo"}],"key":"DzGM8uAlUk"},{"type":"text","value":" is an ordered collection of numbers that represents the state or configuration of a physical system.","key":"dm4dekmpvo"}],"key":"KdPm6lnBBa"},{"type":"list","ordered":false,"start":null,"spread":false,"children":[{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"a = (-2, 8)","key":"PfatdV5G7o"}],"key":"Ms9mzQ0Wua"},{"type":"text","value":", a 2D vector","key":"PNM4Q6I0PK"}],"key":"OBt5x0GJYT"}],"key":"M8Hyz1kakB"},{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_1 = (1,0)","key":"bUdX3ZNOZK"}],"key":"crX4lezhRH"},{"type":"text","value":", a unit vector along the x axis, and ","key":"xfNAz2Uj97"},{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_2 = (0,1)","key":"arHb3SZJNa"}],"key":"MU9HCepSt4"},{"type":"text","value":", a unit vector along the y axis","