, rotation=0)\nax.text(v[0]+0.1, v[1]+0.1, r'$\\mathbf{v} = 2\\mathbf{e_1} + 3\\mathbf{e_2}$', color='royalblue', fontsize=14)\n\n# Axes and labels\nax.axhline(0, color='black', lw=1)\nax.axvline(0, color='black', lw=1)\nax.set_xlabel('x')\nax.set_ylabel('y')\nax.set_title('A vector as a linear combination of basis vectors')\nplt.show()","key":"rdI1qm1wRQ"},{"type":"div","children":[{"type":"div","class":"output","children":[],"key":"JZmf0tdQaF"}],"key":"mnuYn3EJgj"}],"key":"uqpeDBANNC"},{"type":"heading","depth":2,"children":[{"type":"text","value":"Vectors as arrays of numbers","key":"a6Zat7Nxaj"}],"identifier":"vectors-as-arrays-of-numbers","label":"Vectors as arrays of numbers","html_id":"vectors-as-arrays-of-numbers","implicit":true,"key":"YbioJmi35R"},{"type":"paragraph","children":[{"type":"text","value":"A ","key":"LMCsUhPZiE"},{"type":"strong","children":[{"type":"text","value":"vector","key":"auSW9YiVMB"}],"key":"nJrBFbNubn"},{"type":"text","value":" is an ordered collection of numbers that represents the state or configuration of a physical system.","key":"dCN1I9Az7Y"}],"key":"vcs5YJfAaE"},{"type":"list","ordered":false,"start":null,"spread":false,"children":[{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"a = (-2, 8)","key":"iDHgOa1WxV"}],"key":"jINA8iO6Pu"},{"type":"text","value":", a 2D vector","key":"J7bRDxHxQB"}],"key":"SXgTKEEK8w"}],"key":"QOsEN1gRDF"},{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_1 = (1,0)","key":"uWpjHijXeQ"}],"key":"iv3Zeh8FK0"},{"type":"text","value":", a unit vector along the x axis, and ","key":"DYZUFomnWO"},{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_2 = (0,1)","key":"fQJK3MNNvb"}],"key":"AxAJaYXvdQ"},{"type":"text","value":", a unit vector along the y axis","