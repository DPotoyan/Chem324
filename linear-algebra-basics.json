, rotation=0)\nax.text(v[0]+0.1, v[1]+0.1, r'$\\mathbf{v} = 2\\mathbf{e_1} + 3\\mathbf{e_2}$', color='royalblue', fontsize=14)\n\n# Axes and labels\nax.axhline(0, color='black', lw=1)\nax.axvline(0, color='black', lw=1)\nax.set_xlabel('x')\nax.set_ylabel('y')\nax.set_title('A vector as a linear combination of basis vectors')\nplt.show()","key":"a5se9uiWQw"},{"type":"div","children":[{"type":"div","class":"output","children":[],"key":"Se2fQkw9zj"}],"key":"pqMrCyDXSA"}],"key":"Oqedp8kyri"},{"type":"heading","depth":2,"children":[{"type":"text","value":"Vectors as arrays of numbers","key":"dpvDRYTQke"}],"identifier":"vectors-as-arrays-of-numbers","label":"Vectors as arrays of numbers","html_id":"vectors-as-arrays-of-numbers","implicit":true,"key":"eYplzYlbgZ"},{"type":"paragraph","children":[{"type":"text","value":"A ","key":"U4jtGwVDRO"},{"type":"strong","children":[{"type":"text","value":"vector","key":"R5HMiawFpk"}],"key":"dbBE23wmaG"},{"type":"text","value":" is an ordered collection of numbers that represents the state or configuration of a physical system.","key":"gHk9lGSAoz"}],"key":"rRR1ZY4xth"},{"type":"list","ordered":false,"start":null,"spread":false,"children":[{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"a = (-2, 8)","key":"mhEuAK3rQb"}],"key":"cGRtqsApL9"},{"type":"text","value":", a 2D vector","key":"PX88p2c8IT"}],"key":"udtBrfjN3z"}],"key":"U9HkZ3g8TC"},{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_1 = (1,0)","key":"zM1mh16o1J"}],"key":"N8ENONsJf6"},{"type":"text","value":", a unit vector along the x axis, and ","key":"TKYBdvXVFI"},{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_2 = (0,1)","key":"Q55A2MtSfi"}],"key":"QI8lN2Phh9"},{"type":"text","value":", a unit vector along the y axis","