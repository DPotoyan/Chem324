, rotation=0)\nax.text(v[0]+0.1, v[1]+0.1, r'$\\mathbf{v} = 2\\mathbf{e_1} + 3\\mathbf{e_2}$', color='royalblue', fontsize=14)\n\n# Axes and labels\nax.axhline(0, color='black', lw=1)\nax.axvline(0, color='black', lw=1)\nax.set_xlabel('x')\nax.set_ylabel('y')\nax.set_title('A vector as a linear combination of basis vectors')\nplt.show()","key":"BocFyvKGPI"},{"type":"div","children":[{"type":"div","class":"output","children":[],"key":"smL4PhtWlb"}],"key":"vZSjCacZpx"}],"key":"lhriQPCdk7"},{"type":"heading","depth":2,"children":[{"type":"text","value":"Vectors as arrays of numbers","key":"Wdc2Mc7oZW"}],"identifier":"vectors-as-arrays-of-numbers","label":"Vectors as arrays of numbers","html_id":"vectors-as-arrays-of-numbers","implicit":true,"key":"gIk7BRvYAz"},{"type":"paragraph","children":[{"type":"text","value":"A ","key":"GMgO11WQQI"},{"type":"strong","children":[{"type":"text","value":"vector","key":"ci6zfhUXB1"}],"key":"opSx7VkGj6"},{"type":"text","value":" is an ordered collection of numbers that represents the state or configuration of a physical system.","key":"AXKbqI2K4g"}],"key":"b5sm3f3V8n"},{"type":"list","ordered":false,"start":null,"spread":false,"children":[{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"a = (-2, 8)","key":"GKIwZkbo2w"}],"key":"PjKKFd01Pn"},{"type":"text","value":", a 2D vector","key":"RMJ0qnyhZU"}],"key":"RMzMz3gMrz"}],"key":"lCZquF78Vk"},{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_1 = (1,0)","key":"VLffkwsnDB"}],"key":"zYSLQ42OfQ"},{"type":"text","value":", a unit vector along the x axis, and ","key":"GLrEhzc1cp"},{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_2 = (0,1)","key":"IUHRJvhORg"}],"key":"O1qvq6cce2"},{"type":"text","value":", a unit vector along the y axis","