, rotation=0)\nax.text(v[0]+0.1, v[1]+0.1, r'$\\mathbf{v} = 2\\mathbf{e_1} + 3\\mathbf{e_2}$', color='royalblue', fontsize=14)\n\n# Axes and labels\nax.axhline(0, color='black', lw=1)\nax.axvline(0, color='black', lw=1)\nax.set_xlabel('x')\nax.set_ylabel('y')\nax.set_title('A vector as a linear combination of basis vectors')\nplt.show()","key":"ZzL1EX0BgJ"},{"type":"div","children":[{"type":"div","class":"output","children":[],"key":"uEhiefRMzm"}],"key":"eTZvpStFY4"}],"key":"NqJDbYCNmA"},{"type":"heading","depth":2,"children":[{"type":"text","value":"Vectors as arrays of numbers","key":"XnMB2qY1Jf"}],"identifier":"vectors-as-arrays-of-numbers","label":"Vectors as arrays of numbers","html_id":"vectors-as-arrays-of-numbers","implicit":true,"key":"xhLRhiviIi"},{"type":"paragraph","children":[{"type":"text","value":"A ","key":"mqiFGwdJEa"},{"type":"strong","children":[{"type":"text","value":"vector","key":"gXI2tHEKGB"}],"key":"x4F5b9uYeY"},{"type":"text","value":" is an ordered collection of numbers that represents the state or configuration of a physical system.","key":"Ef3cRWCJ96"}],"key":"XkfPoIGDwa"},{"type":"list","ordered":false,"start":null,"spread":false,"children":[{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"a = (-2, 8)","key":"mBdKbvNWSj"}],"key":"TQV8WCJgKZ"},{"type":"text","value":", a 2D vector","key":"iRlq2C2x0Y"}],"key":"nVCGFPYeey"}],"key":"ichBThsVGa"},{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_1 = (1,0)","key":"D7INk7f1iV"}],"key":"S6C1qNQfgj"},{"type":"text","value":", a unit vector along the x axis, and ","key":"BfUSvjPMCY"},{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_2 = (0,1)","key":"AplcRSBmFp"}],"key":"iXSS3D0sX1"},{"type":"text","value":", a unit vector along the y axis","