, rotation=0)\nax.text(v[0]+0.1, v[1]+0.1, r'$\\mathbf{v} = 2\\mathbf{e_1} + 3\\mathbf{e_2}$', color='royalblue', fontsize=14)\n\n# Axes and labels\nax.axhline(0, color='black', lw=1)\nax.axvline(0, color='black', lw=1)\nax.set_xlabel('x')\nax.set_ylabel('y')\nax.set_title('A vector as a linear combination of basis vectors')\nplt.show()","key":"GZ99PnsOS4"},{"type":"div","children":[{"type":"div","class":"output","children":[],"key":"Y13l8j4lND"}],"key":"IfTNjUqyco"}],"key":"uNktGrn3bt"},{"type":"heading","depth":2,"children":[{"type":"text","value":"Vectors as arrays of numbers","key":"E4UNtCfONF"}],"identifier":"vectors-as-arrays-of-numbers","label":"Vectors as arrays of numbers","html_id":"vectors-as-arrays-of-numbers","implicit":true,"key":"GoV9G8Sjmd"},{"type":"paragraph","children":[{"type":"text","value":"A ","key":"bUlwY0ySFj"},{"type":"strong","children":[{"type":"text","value":"vector","key":"e7bndv3vsM"}],"key":"e7zBJdMod0"},{"type":"text","value":" is an ordered collection of numbers that represents the state or configuration of a physical system.","key":"f11wHbBQh1"}],"key":"ELooDFtrQR"},{"type":"list","ordered":false,"start":null,"spread":false,"children":[{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"a = (-2, 8)","key":"EWhAdaUQXn"}],"key":"yo5PagO8Uv"},{"type":"text","value":", a 2D vector","key":"alBCjF9B5F"}],"key":"iOLVK44UaU"}],"key":"BUntccUQwd"},{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_1 = (1,0)","key":"cPnkdMcLIi"}],"key":"nFFWvN0dIH"},{"type":"text","value":", a unit vector along the x axis, and ","key":"ZtEY7zuMWg"},{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_2 = (0,1)","key":"xu1GKKesLf"}],"key":"x0cnpWdnOs"},{"type":"text","value":", a unit vector along the y axis","