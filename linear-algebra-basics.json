, rotation=0)\nax.text(v[0]+0.1, v[1]+0.1, r'$\\mathbf{v} = 2\\mathbf{e_1} + 3\\mathbf{e_2}$', color='royalblue', fontsize=14)\n\n# Axes and labels\nax.axhline(0, color='black', lw=1)\nax.axvline(0, color='black', lw=1)\nax.set_xlabel('x')\nax.set_ylabel('y')\nax.set_title('A vector as a linear combination of basis vectors')\nplt.show()","key":"lGRIFNNsAP"},{"type":"div","children":[],"key":"ctZFRQs8RX"}],"key":"huok0Mk9O7"},{"type":"heading","depth":2,"children":[{"type":"text","value":"Vectors as arrays of numbers","key":"tQUrJeYwDW"}],"identifier":"vectors-as-arrays-of-numbers","label":"Vectors as arrays of numbers","html_id":"vectors-as-arrays-of-numbers","implicit":true,"key":"tVlJc7sOET"},{"type":"paragraph","children":[{"type":"text","value":"A ","key":"r3l8KGrH6z"},{"type":"strong","children":[{"type":"text","value":"vector","key":"Wm4F3NVuUN"}],"key":"YWnRVZrmna"},{"type":"text","value":" is an ordered collection of numbers that represents the state or configuration of a physical system.","key":"hMHNTrtcXu"}],"key":"MZLTqcIkFt"},{"type":"list","ordered":false,"start":null,"spread":false,"children":[{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"a = (-2, 8)","key":"sjee7KhWi9"}],"key":"XGQN4kyJNw"},{"type":"text","value":", a 2D vector","key":"nF96ehapvR"}],"key":"VOkFmbXqw8"}],"key":"YIyX3tVbIZ"},{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_1 = (1,0)","key":"sG4kFLkpxA"}],"key":"uC9qy115rs"},{"type":"text","value":", a unit vector along the x axis, and ","key":"lzca4FnUyY"},{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_2 = (0,1)","key":"ddqSM5JQDY"}],"key":"uYJCnjmCPb"},{"type":"text","value":", a unit vector along the y axis","key":"JjjlelCxBq"}],"key":"VOJ6GmlUea"}],"key":"Cu2SEvTrFC"},{"t