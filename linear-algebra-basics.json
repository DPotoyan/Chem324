, rotation=0)\nax.text(v[0]+0.1, v[1]+0.1, r'$\\mathbf{v} = 2\\mathbf{e_1} + 3\\mathbf{e_2}$', color='royalblue', fontsize=14)\n\n# Axes and labels\nax.axhline(0, color='black', lw=1)\nax.axvline(0, color='black', lw=1)\nax.set_xlabel('x')\nax.set_ylabel('y')\nax.set_title('A vector as a linear combination of basis vectors')\nplt.show()","key":"WE9Ow5DdqH"},{"type":"div","children":[{"type":"div","class":"output","children":[],"key":"mDFkT2j4Sm"}],"key":"KeMXdKuEFc"}],"key":"Pv6HOzbwOw"},{"type":"heading","depth":2,"children":[{"type":"text","value":"Vectors as arrays of numbers","key":"jBIucC7mmb"}],"identifier":"vectors-as-arrays-of-numbers","label":"Vectors as arrays of numbers","html_id":"vectors-as-arrays-of-numbers","implicit":true,"key":"x0a1UGipKw"},{"type":"paragraph","children":[{"type":"text","value":"A ","key":"DN59beBCfY"},{"type":"strong","children":[{"type":"text","value":"vector","key":"P4OtqjWx9w"}],"key":"x9egUZj68e"},{"type":"text","value":" is an ordered collection of numbers that represents the state or configuration of a physical system.","key":"z10Ye6s3Nc"}],"key":"VwkQspqFs5"},{"type":"list","ordered":false,"start":null,"spread":false,"children":[{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"a = (-2, 8)","key":"cU4LENDMZA"}],"key":"AdG54zR3Cc"},{"type":"text","value":", a 2D vector","key":"VqQmLsPelm"}],"key":"K29oBy4wK5"}],"key":"YQJoIzoSPD"},{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_1 = (1,0)","key":"zJUlx23Mb7"}],"key":"z55qM27acF"},{"type":"text","value":", a unit vector along the x axis, and ","key":"bs1FEAQHai"},{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_2 = (0,1)","key":"kg3H7EeiMB"}],"key":"I4NEHGU8BQ"},{"type":"text","value":", a unit vector along the y axis","