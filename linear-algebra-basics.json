, rotation=0)\nax.text(v[0]+0.1, v[1]+0.1, r'$\\mathbf{v} = 2\\mathbf{e_1} + 3\\mathbf{e_2}$', color='royalblue', fontsize=14)\n\n# Axes and labels\nax.axhline(0, color='black', lw=1)\nax.axvline(0, color='black', lw=1)\nax.set_xlabel('x')\nax.set_ylabel('y')\nax.set_title('A vector as a linear combination of basis vectors')\nplt.show()","key":"Hj3LVVln9I"},{"type":"div","children":[],"key":"AwH9BHXpgI"}],"key":"Z98yN9Hnh9"},{"type":"heading","depth":2,"children":[{"type":"text","value":"Vectors as arrays of numbers","key":"PP0n1JUi30"}],"identifier":"vectors-as-arrays-of-numbers","label":"Vectors as arrays of numbers","html_id":"vectors-as-arrays-of-numbers","implicit":true,"key":"wyYqNFXLS0"},{"type":"paragraph","children":[{"type":"text","value":"A ","key":"GkCu2H7SMp"},{"type":"strong","children":[{"type":"text","value":"vector","key":"DRqEf1nzWB"}],"key":"waz9lENOlS"},{"type":"text","value":" is an ordered collection of numbers that represents the state or configuration of a physical system.","key":"NZEiShS8O0"}],"key":"VXt8VLIwSw"},{"type":"list","ordered":false,"start":null,"spread":false,"children":[{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"a = (-2, 8)","key":"uvHaEfAhbb"}],"key":"qE6RtxFTVl"},{"type":"text","value":", a 2D vector","key":"viIVf8iHoU"}],"key":"Q6wFxIhO6W"}],"key":"e3lS0oaStC"},{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_1 = (1,0)","key":"tYfx7IsJs5"}],"key":"KhxR6v9buB"},{"type":"text","value":", a unit vector along the x axis, and ","key":"mvIp6E2HRY"},{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_2 = (0,1)","key":"B4l6TNkCl1"}],"key":"rym2UsGJZr"},{"type":"text","value":", a unit vector along the y axis","key":"sMPihHz3vy"}],"key":"YB2WzzchCX"}],"key":"wRlhKEy7DD"},{"t