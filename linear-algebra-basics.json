, rotation=0)\nax.text(v[0]+0.1, v[1]+0.1, r'$\\mathbf{v} = 2\\mathbf{e_1} + 3\\mathbf{e_2}$', color='royalblue', fontsize=14)\n\n# Axes and labels\nax.axhline(0, color='black', lw=1)\nax.axvline(0, color='black', lw=1)\nax.set_xlabel('x')\nax.set_ylabel('y')\nax.set_title('A vector as a linear combination of basis vectors')\nplt.show()","key":"XL9xJrNbFy"},{"type":"div","children":[],"key":"EP1tdLZKEn"}],"key":"rxoA1c9Rd5"},{"type":"heading","depth":2,"children":[{"type":"text","value":"Vectors as arrays of numbers","key":"g9BqC9lewD"}],"identifier":"vectors-as-arrays-of-numbers","label":"Vectors as arrays of numbers","html_id":"vectors-as-arrays-of-numbers","implicit":true,"key":"cqKVBYAlSG"},{"type":"paragraph","children":[{"type":"text","value":"A ","key":"DOP5r70hME"},{"type":"strong","children":[{"type":"text","value":"vector","key":"J6kYy2BV80"}],"key":"tWhGmQtyae"},{"type":"text","value":" is an ordered collection of numbers that represents the state or configuration of a physical system.","key":"iL9SHxTQqF"}],"key":"yGata2DlMY"},{"type":"list","ordered":false,"start":null,"spread":false,"children":[{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"a = (-2, 8)","key":"JjqWz0PwZq"}],"key":"WhzYGgfqMZ"},{"type":"text","value":", a 2D vector","key":"Hj76lMA4iL"}],"key":"QyOwFQFjLC"}],"key":"q0Gr602IEX"},{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_1 = (1,0)","key":"S1v8yGztDu"}],"key":"u3TaEPEYtE"},{"type":"text","value":", a unit vector along the x axis, and ","key":"pAYGr9OwxV"},{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_2 = (0,1)","key":"ZJeHogLeeq"}],"key":"HJKvoqTsEu"},{"type":"text","value":", a unit vector along the y axis","key":"BRh67qOmBd"}],"key":"TZJbR1ZRot"}],"key":"Xnww6ITV4c"},{"t