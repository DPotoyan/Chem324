, rotation=0)\nax.text(v[0]+0.1, v[1]+0.1, r'$\\mathbf{v} = 2\\mathbf{e_1} + 3\\mathbf{e_2}$', color='royalblue', fontsize=14)\n\n# Axes and labels\nax.axhline(0, color='black', lw=1)\nax.axvline(0, color='black', lw=1)\nax.set_xlabel('x')\nax.set_ylabel('y')\nax.set_title('A vector as a linear combination of basis vectors')\nplt.show()","key":"C49CnIN86T"},{"type":"div","children":[{"type":"div","class":"output","children":[],"key":"Kd8hHOQMPR"}],"key":"YuomBMlZb4"}],"key":"Y6KvYYkKYN"},{"type":"heading","depth":2,"children":[{"type":"text","value":"Vectors as arrays of numbers","key":"QEKszDhbG8"}],"identifier":"vectors-as-arrays-of-numbers","label":"Vectors as arrays of numbers","html_id":"vectors-as-arrays-of-numbers","implicit":true,"key":"aQNhKovOQS"},{"type":"paragraph","children":[{"type":"text","value":"A ","key":"Jwjkdp622e"},{"type":"strong","children":[{"type":"text","value":"vector","key":"zzhSlnUYy7"}],"key":"DhwJCPEdji"},{"type":"text","value":" is an ordered collection of numbers that represents the state or configuration of a physical system.","key":"qkUQcivXEX"}],"key":"QPBTvEmZTE"},{"type":"list","ordered":false,"start":null,"spread":false,"children":[{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"a = (-2, 8)","key":"uxYEZa574F"}],"key":"ybYV4nZMu4"},{"type":"text","value":", a 2D vector","key":"SkcW5Nc3NM"}],"key":"daOgyEglcy"}],"key":"WlJSkaOmEI"},{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_1 = (1,0)","key":"YE2V88rkiD"}],"key":"MOufU4IWYG"},{"type":"text","value":", a unit vector along the x axis, and ","key":"rFxUrT1QtQ"},{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_2 = (0,1)","key":"LIIukh25f4"}],"key":"bfvKl9HyFs"},{"type":"text","value":", a unit vector along the y axis","