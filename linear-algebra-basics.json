, rotation=0)\nax.text(v[0]+0.1, v[1]+0.1, r'$\\mathbf{v} = 2\\mathbf{e_1} + 3\\mathbf{e_2}$', color='royalblue', fontsize=14)\n\n# Axes and labels\nax.axhline(0, color='black', lw=1)\nax.axvline(0, color='black', lw=1)\nax.set_xlabel('x')\nax.set_ylabel('y')\nax.set_title('A vector as a linear combination of basis vectors')\nplt.show()","key":"UvKoGjN57i"},{"type":"div","children":[],"key":"aRVCvZBrGE"}],"key":"LB0imCbasV"},{"type":"heading","depth":2,"children":[{"type":"text","value":"Vectors as arrays of numbers","key":"B3LpH3a5vH"}],"identifier":"vectors-as-arrays-of-numbers","label":"Vectors as arrays of numbers","html_id":"vectors-as-arrays-of-numbers","implicit":true,"key":"B6OUfhDZAj"},{"type":"paragraph","children":[{"type":"text","value":"A ","key":"ra43xTuj0m"},{"type":"strong","children":[{"type":"text","value":"vector","key":"j68edec0fT"}],"key":"wZ5remMqYG"},{"type":"text","value":" is an ordered collection of numbers that represents the state or configuration of a physical system.","key":"cSUW6LKOaH"}],"key":"wLoyf846VZ"},{"type":"list","ordered":false,"start":null,"spread":false,"children":[{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"a = (-2, 8)","key":"YDTYA4mWFZ"}],"key":"OIQNXMrYuZ"},{"type":"text","value":", a 2D vector","key":"Lt20HirO7R"}],"key":"e9TGO1aRPh"}],"key":"rYr7sRIvDO"},{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_1 = (1,0)","key":"GMq86oEsjl"}],"key":"lMx5LIE5aQ"},{"type":"text","value":", a unit vector along the x axis, and ","key":"GBI5VCdELB"},{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_2 = (0,1)","key":"NQA1Q6WsC0"}],"key":"uIjhRMAu8v"},{"type":"text","value":", a unit vector along the y axis","key":"wLVzH0kzh7"}],"key":"qmesxQiVsF"}],"key":"tT3nsdwmkO"},{"t