, rotation=0)\nax.text(v[0]+0.1, v[1]+0.1, r'$\\mathbf{v} = 2\\mathbf{e_1} + 3\\mathbf{e_2}$', color='royalblue', fontsize=14)\n\n# Axes and labels\nax.axhline(0, color='black', lw=1)\nax.axvline(0, color='black', lw=1)\nax.set_xlabel('x')\nax.set_ylabel('y')\nax.set_title('A vector as a linear combination of basis vectors')\nplt.show()","key":"g8lN67kU7L"},{"type":"div","children":[{"type":"div","class":"output","children":[],"key":"zBW2XXmEl7"}],"key":"Ict8BIIr7U"}],"key":"LeDi352Oxf"},{"type":"heading","depth":2,"children":[{"type":"text","value":"Vectors as arrays of numbers","key":"VovRtZzNE5"}],"identifier":"vectors-as-arrays-of-numbers","label":"Vectors as arrays of numbers","html_id":"vectors-as-arrays-of-numbers","implicit":true,"key":"RMgipHuA5d"},{"type":"paragraph","children":[{"type":"text","value":"A ","key":"cIjU1uqICI"},{"type":"strong","children":[{"type":"text","value":"vector","key":"o6lHGOSFd1"}],"key":"Sm6NITpPns"},{"type":"text","value":" is an ordered collection of numbers that represents the state or configuration of a physical system.","key":"UJeeTzPAHC"}],"key":"UdRFG2RQ7j"},{"type":"list","ordered":false,"start":null,"spread":false,"children":[{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"a = (-2, 8)","key":"noBmngG8nR"}],"key":"xvMlvzMGY4"},{"type":"text","value":", a 2D vector","key":"sCMpKFUW0S"}],"key":"G6Xh7opao9"}],"key":"FRO4ABGeJN"},{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_1 = (1,0)","key":"FqMg4zsuKx"}],"key":"zLVJXT0xvi"},{"type":"text","value":", a unit vector along the x axis, and ","key":"ejuDac6wGi"},{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_2 = (0,1)","key":"ugzPOTgFgb"}],"key":"n0qfufIEhj"},{"type":"text","value":", a unit vector along the y axis","