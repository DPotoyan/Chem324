, rotation=0)\nax.text(v[0]+0.1, v[1]+0.1, r'$\\mathbf{v} = 2\\mathbf{e_1} + 3\\mathbf{e_2}$', color='royalblue', fontsize=14)\n\n# Axes and labels\nax.axhline(0, color='black', lw=1)\nax.axvline(0, color='black', lw=1)\nax.set_xlabel('x')\nax.set_ylabel('y')\nax.set_title('A vector as a linear combination of basis vectors')\nplt.show()","key":"Lb3bMEeiUm"},{"type":"div","children":[{"type":"div","class":"output","children":[],"key":"rZtiJTNk9u"}],"key":"salxGYRPRA"}],"key":"aJuEfJzXyg"},{"type":"heading","depth":2,"children":[{"type":"text","value":"Vectors as arrays of numbers","key":"FpD6xEWOZU"}],"identifier":"vectors-as-arrays-of-numbers","label":"Vectors as arrays of numbers","html_id":"vectors-as-arrays-of-numbers","implicit":true,"key":"WUbQEritCn"},{"type":"paragraph","children":[{"type":"text","value":"A ","key":"UXWpw6s0M9"},{"type":"strong","children":[{"type":"text","value":"vector","key":"ORdoW0exnE"}],"key":"ZJWvr80IrL"},{"type":"text","value":" is an ordered collection of numbers that represents the state or configuration of a physical system.","key":"YrcM0oocRS"}],"key":"IJEyqTxGq1"},{"type":"list","ordered":false,"start":null,"spread":false,"children":[{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"a = (-2, 8)","key":"cAdUzrCpNd"}],"key":"isC9jFOTz8"},{"type":"text","value":", a 2D vector","key":"J5ExyTuSQi"}],"key":"dXhTBu2OBW"}],"key":"TDjJsWQ9mQ"},{"type":"listItem","spread":false,"checked":null,"children":[{"type":"paragraph","children":[{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_1 = (1,0)","key":"CuHZArQeFv"}],"key":"ZnSF2M8Kqn"},{"type":"text","value":", a unit vector along the x axis, and ","key":"uMxWZ7RfUm"},{"type":"span","class":"math-inline","children":[{"type":"text","value":"e_2 = (0,1)","key":"eq4bkls7Ss"}],"key":"slnWk99KBb"},{"type":"text","value":", a unit vector along the y axis","