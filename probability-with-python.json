"dVDtrUyngZ"},{"type":"outputs","id":"rQJ24AmgD8CYuzMeeKu1c","children":[],"key":"UHFiw1XfQV"}],"key":"gCHDRXkXqd"},{"type":"block","kind":"notebook-content","children":[{"type":"paragraph","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"Lets make a plot of uniform distribution","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"umPsk2xwAh"}],"key":"MjNs6BQAMy"}],"key":"TYOMFeMygY"},{"type":"block","kind":"notebook-code","data":{"slideshow":{"slide_type":"slide"}},"children":[{"type":"code","lang":"python","executable":true,"value":"def plot_unif(a, b):\n    \n    x = np.linspace(a,b,1000)  # The range needs to be inside a and b\n    \n    y = p_unif(x, a, b)       # Notice how we are using a function defined before instead of recreating again. \n    \n    plt.plot(x, y, lw=5)\n    \n    plt.xlim([a, b])","key":"ErsATVInJF"},{"type":"outputs","id":"WgPv3rTJbx8liW5ebEJeu","children":[],"key":"Xpirk9bwBJ"}],"key":"VmMSKfEHrH"},{"type":"block","kind":"notebook-code","data":{"slideshow":{"slide_type":"fragment"}},"children":[{"type":"code","lang":"python","executable":true,"value":"plot_unif(1,2)\nplot_unif(1,2.5)\nplot_unif(1,3)","key":"AhA12ojOaF"},{"type":"outputs","id":"qsg7pCS_GjTTqtbSC1N9z","children":[],"key":"ugnzecMtqd"}],"key":"SNhs3oabXj"},{"type":"block","kind":"notebook-code","data":{"slideshow":{"slide_type":"slide"}},"children":[{"type":"code","lang":"python","executable":true,"value":"@widgets.interact(b=(2,20))\n\ndef plot_uniform(b):\n    \n    x = np.linspace(1,b,1000)  # We fixed a at 1 and only vary b\n    \n    y = p_unif(x, 1, b)       \n    \n    plt.plot(x, y, lw=5)\n    \n    plt.ylim([0,1])","key":"QQuT9oOTMY"},{"type":"outputs","id":"lZnSSx1IlYj8xDb1YGFDs","children":[],"key":"hRWEV9OZR3"}],"key":"DWtlFsnjFY"}],"key":"uI2DVa4qxL"},"references":{"cite":{"order":[],"data":{}}},"footer":{"navigation":{"prev":{"title":"Symbolic Math with SymPy","url":"/symbolic-